---
import { isGeminiConfigured } from '../lib/gemini';
import { initialAssistantMessage } from '../lib/onboarding-ai';
import { SETUP_PHASES } from '../lib/setup-phases';
import { publicLogoPreview } from '../lib/setup-phases';
import { getServices, getTenantById } from '../lib/store';

interface Props {
  tenantId: string;
  businessName: string;
  ownerName: string;
  currency: string;
}

const { tenantId, businessName, ownerName, currency } = Astro.props;
const tenant = await getTenantById(tenantId);
const greeting = tenant ? initialAssistantMessage(tenant, 'assistant') : '';
const onboardingComplete = tenant?.onboardingComplete === true;
const geminiOk = isGeminiConfigured();
const services = tenant ? await getServices(tenantId) : [];
const serviceCount = services.filter((s) => s.active).length;
const logoUrl = tenant ? publicLogoPreview(tenant) : '';
---

<div
  id="assistant-panel-root"
  class="assistant-root"
  data-greeting={JSON.stringify(greeting)}
  data-currency={currency}
  data-business={businessName}
  data-logo-url={logoUrl}
  data-service-count={serviceCount}
  data-onboarding-complete={onboardingComplete ? '1' : '0'}
>
  <button type="button" id="assistant-fab" class="assistant-fab" aria-label="Abrir asistente">
    <svg class="assistant-fab__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
      <circle cx="6" cy="7" r="2.5"/><circle cx="6" cy="17" r="2.5"/>
      <path d="M8.5 8.5L20 3M8.5 15.5L20 21M20 3L14 12L20 21"/>
    </svg>
  </button>

  <div id="assistant-backdrop" class="assistant-backdrop" aria-hidden="true"></div>

  <aside id="assistant-drawer" class="assistant-drawer" aria-hidden="true" aria-label="Asistente de configuración">
    <div class="assistant-drawer__deco" aria-hidden="true">
      <svg class="assistant-drawer__deco-comb" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.2">
        <rect x="10" y="8" width="28" height="32" rx="4"/>
        <path d="M16 16h16M16 22h16M16 28h12"/>
      </svg>
      <svg class="assistant-drawer__deco-scissors" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5">
        <circle cx="14" cy="14" r="4"/><circle cx="14" cy="34" r="4"/>
        <path d="M17 17L38 8M17 31L38 40M38 8L28 24L38 40"/>
      </svg>
    </div>
    <header class="assistant-drawer__head">
      <div>
        <p class="assistant-drawer__eyebrow">Configuración · Agenda</p>
        <p class="assistant-drawer__title">Asistente · {businessName}</p>
        <p id="assistant-gemini-badge" class:list={['config-gemini-badge config-gemini-badge--sm', geminiOk && 'hidden']}>
          Modo básico
        </p>
      </div>
      <button type="button" id="assistant-close" class="assistant-drawer__close" aria-label="Cerrar">×</button>
    </header>

    <div class:list={['setup-phases setup-phases--compact', onboardingComplete && 'hidden']} id="assistant-phases">
      <p class="setup-phases__label" data-phase-label>{SETUP_PHASES[0].short}</p>
      <div class="setup-phases__track">
        {SETUP_PHASES.map((p) => (
          <span class="setup-phases__step" data-phase={p.id} data-phase-label={p.short} title={p.label} />
        ))}
      </div>
    </div>

    <div class="assistant-drawer__scroll">
      <div id="assistant-messages" class="assistant-drawer__messages"></div>
    </div>

    <div class="assistant-drawer__dock">
      <div id="assistant-preview" class="assistant-drawer__preview hidden"></div>
      <div id="assistant-chips" class="chat-chips chat-chips--drawer hidden"></div>

      <form id="assistant-form" class="assistant-drawer__form config-composer">
        <input type="file" id="assistant-logo-file" class="sr-only" accept="image/png,image/jpeg,image/webp" />
        <button type="button" id="assistant-logo-attach" class="config-composer__attach" aria-label="Subir logo">📎</button>
        <input
          id="assistant-input"
          class="input"
          type="text"
          placeholder="Escribe aquí…"
          autocomplete="off"
        />
        <button type="submit" class="btn-primary btn-sm">Enviar</button>
      </form>

      <footer class="assistant-drawer__foot">
        <button type="button" id="assistant-apply" class="btn-accent btn-sm hidden w-full">Aplicar cambios</button>
      </footer>
    </div>
  </aside>
</div>

<script>
  import { initAssistantPanel } from '../scripts/assistant-panel.js';
  initAssistantPanel();
</script>
