---
interface Props {
  name: string;
  class?: string;
}

const { name, class: className = '' } = Astro.props;
---

<span class:list={['landing-icon', className]} aria-hidden="true">
  {name === 'ai' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
      <path d="M12 3v2M12 19v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M3 12h2M19 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4" />
      <circle cx="12" cy="12" r="4" />
      <path d="M8 16l-2 4M16 16l2 4" />
    </svg>
  )}
  {name === 'bay' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
      <rect x="3" y="4" width="18" height="17" rx="2" />
      <path d="M3 9h18M8 4V2M16 4V2M7 13h4M7 17h6" />
    </svg>
  )}
  {name === 'book' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
      <path d="M10 13a5 5 0 0 1 7 0M8.5 16.5a8.5 8.5 0 1 1 0-9" />
      <path d="M14 8h5v13H6" />
    </svg>
  )}
  {name === 'notify' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
      <path d="M18 8a6 6 0 1 0-12 0c0 7-3 8-3 8h18s-3-1-3-8" />
      <path d="M10 20a2 2 0 0 0 4 0" />
    </svg>
  )}
  {name === 'wait' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
      <circle cx="12" cy="12" r="9" />
      <path d="M12 7v5l3 2" />
    </svg>
  )}
  {name === 'brand' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
      <rect x="4" y="4" width="16" height="16" rx="3" />
      <circle cx="9" cy="10" r="2" />
      <path d="M4 16l4-4 3 3 5-6 4 5" />
    </svg>
  )}
  {name === 'spark' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
      <path d="M12 2l1.5 5.5L19 9l-5.5 1.5L12 16l-1.5-5.5L5 9l5.5-1.5L12 2z" />
      <path d="M5 3l.8 2.2L8 6l-2.2.8L5 9l-.8-2.2L2 6l2.2-.8L5 3zM19 14l.8 2.2L22 17l-2.2.8L19 20l-.8-2.2L16 17l2.2-.8L19 14z" />
    </svg>
  )}
</span>
