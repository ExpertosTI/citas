---
import { APPOINTMENT_COLORS, type Service } from '../lib/store';
import { publicServiceMeta } from '../lib/service-display';
import { countryPreset } from '../lib/geo';

interface Props {
  slug: string;
  services: Service[];
  currency: string;
  whatsapp: string;
  country: string;
  accentColor: string;
  timezone?: string;
  waitlistEnabled?: boolean;
}

const { slug, services, currency, whatsapp, country, accentColor, timezone = 'America/Santo_Domingo', waitlistEnabled = true } = Astro.props;
const phonePreset = countryPreset(country);
const totalSteps = 4;
---

<div
  id="book-wizard"
  class="flow-wizard card overflow-hidden rounded-[1.75rem] p-5 sm:p-7"
  data-slug={slug}
  data-whatsapp={whatsapp}
  data-country={country}
  data-timezone={timezone}
  data-total={totalSteps}
>
  <div class="mb-5 flex gap-2" aria-hidden="true">
    {Array.from({ length: totalSteps }, (_, i) => (
      <div class="step-dot" data-step-dot={i + 1}></div>
    ))}
  </div>

  <p id="book-step-label" class="wizard-kicker mb-4">Paso 1 de {totalSteps}</p>

  <form id="book-form" novalidate>
    <fieldset data-step="1" class="step-panel space-y-3">
      <legend class="wizard-title mb-3 block">¿Qué servicio?</legend>
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
        {services.map((s) => {
          const color = APPOINTMENT_COLORS.find((c) => c.id === s.color)?.hex || '#c9a227';
          return (
            <label class="flow-choice choice-card cursor-pointer" style={`border-left: 3px solid ${color}`}>
              <input type="radio" name="serviceId" value={s.id} class="sr-only" required />
              <span class="flow-choice__body">
                {s.imageUrl ? (
                  <img src={s.imageUrl} alt="" class="mb-2 h-12 w-12 rounded-lg object-cover" />
                ) : null}
                <span class="flow-choice__title">{s.name}</span>
                <span class="flow-choice__meta">{publicServiceMeta(s, currency)}</span>
              </span>
              <span class="flow-radio" aria-hidden="true"></span>
            </label>
          );
        })}
      </div>
    </fieldset>

    <fieldset data-step="2" class="step-panel hidden space-y-3">
      <legend class="wizard-title mb-3 block">¿Qué día?</legend>
      <p class="wizard-sub mb-2">Elige una fecha disponible</p>
      <div id="date-grid" class="date-grid"></div>
      <input type="hidden" name="date" id="date-hidden" required />
    </fieldset>

    <fieldset data-step="3" class="step-panel hidden space-y-3">
      <legend class="wizard-title mb-3 block">¿A qué hora?</legend>
      <div id="slots-grid" class="grid grid-cols-1 gap-3 sm:grid-cols-2"></div>
      {waitlistEnabled && (
        <button type="button" id="book-waitlist" class="btn-ghost mt-2 w-full !text-xs">
          Avisarme si se libera un cupo
        </button>
      )}
    </fieldset>

    <fieldset data-step="4" class="step-panel hidden space-y-3">
      <legend class="wizard-title mb-3 block">Tus datos</legend>
      <label class="block">
        <span class="label">Nombre</span>
        <input class="field" id="name" name="name" required autocomplete="name" />
      </label>
      <div class="grid grid-cols-2 gap-3">
        <label class="block sm:col-span-2">
          <span class="label">Teléfono</span>
          <div class="phone-input-group">
            <span class="phone-input-group__prefix">{phonePreset.phonePrefix}</span>
            <input class="field phone-input-group__field" id="phone" name="phone" type="tel" placeholder={phonePreset.phoneExample} inputmode="tel" autocomplete="tel" required />
          </div>
        </label>
        <label class="block">
          <span class="label">Email</span>
          <input class="field" id="email" name="email" type="email" autocomplete="email" />
        </label>
      </div>
      <label class="block">
        <span class="label">Notas</span>
        <textarea class="field min-h-[72px] resize-y" id="notes" name="notes" rows="2" placeholder="Detalles extra para tu cita"></textarea>
      </label>
    </fieldset>

    <p id="book-error" class="mt-4 hidden text-sm font-medium text-danger" role="alert"></p>

    <div class="mt-6 flex gap-3">
      <button type="button" id="book-back" class="btn-ghost hidden flex-1">Atrás</button>
      <button type="button" id="book-next" class="btn-primary flex-1">Continuar</button>
      <button type="submit" id="book-submit" class="btn-primary hidden flex-1">Confirmar cita</button>
    </div>
  </form>

  <div id="book-success" class="hidden py-8 text-center">
    <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-gold-dim text-2xl text-mustard-deep">✓</div>
    <h3 class="wizard-title text-2xl">¡Listo!</h3>
    <p class="mt-2 text-sm text-muted">Recibimos tu solicitud. Te confirmamos en breve.</p>
    <p id="book-success-when" class="mt-2 text-sm text-muted"></p>
    <p class="mt-4 text-xs font-semibold uppercase tracking-wider text-muted">Código</p>
    <p id="book-success-code" class="brand-mark text-4xl"></p>
    <div class="mt-6 flex flex-col gap-3 sm:mx-auto sm:max-w-sm">
      <a id="book-wa" class="btn-wa w-full" href="#" target="_blank" rel="noopener noreferrer">WhatsApp</a>
      <button type="button" id="book-again" class="btn-ghost w-full">Otra cita</button>
    </div>
  </div>
</div>

<script>
  import { initBookWizard } from '../scripts/book-wizard.js';
  initBookWizard();
</script>
