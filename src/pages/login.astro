---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Entrar · Citas">
  <div class="app-scene min-h-dvh">
    <div class="accent-line"></div>
    <div class="mx-auto flex min-h-dvh max-w-md flex-col justify-center px-4 py-10">
    <a href="/" class="brand-mark mb-8 text-4xl">Citas</a>
    <div class="card p-6 sm:p-8">
      <h1 class="brand-mark text-4xl leading-none">Entrar</h1>
      <p class="mt-2 text-sm text-ink-soft">Accede a tu bahía de citas.</p>

      <form id="login-form" class="mt-6 space-y-4">
        <div>
          <label class="label" for="email">Email</label>
          <input class="input" id="email" name="email" type="email" required />
        </div>
        <div>
          <label class="label" for="password">Contraseña</label>
          <input class="input" id="password" name="password" type="password" required />
        </div>
        <p id="form-error" class="hidden text-sm font-medium text-danger"></p>
        <button class="btn-primary w-full !py-3" type="submit">Entrar</button>
      </form>

      <p class="mt-5 text-center text-sm text-muted">
        ¿Nuevo? <a class="font-semibold text-gold" href="/registro">Crear negocio</a>
      </p>
    </div>
    </div>
  </div>

  <script>
    const form = document.getElementById('login-form') as HTMLFormElement;
    const errorEl = document.getElementById('form-error')!;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorEl.classList.add('hidden');
      const data = Object.fromEntries(new FormData(form).entries());
      const res = await fetch('/api/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify(data),
      });
      const json = await res.json();
      if (!res.ok) {
        errorEl.textContent = json.error || 'Error al entrar';
        errorEl.classList.remove('hidden');
        return;
      }
      location.href = json.tenant?.onboardingComplete === false ? '/app/onboarding' : '/app';
    });
  </script>
</BaseLayout>
