---
import BaseLayout from '../layouts/BaseLayout.astro';
import GoogleSignIn from '../components/GoogleSignIn.astro';
import { isGoogleAuthConfigured } from '../lib/google-auth';

const googleAuth = isGoogleAuthConfigured();
const authErrors: Record<string, string> = {
  google_no_account: 'No hay cuenta con ese Google. Crea tu negocio primero.',
  google_denied: 'Cancelaste el acceso con Google.',
  google_unverified: 'Tu email de Google no está verificado.',
  google_invalid: 'La sesión de Google expiró. Intenta de nuevo.',
  google_failed: 'No pudimos conectar con Google. Intenta de nuevo.',
  google_unavailable: 'Inicio con Google no disponible ahora.',
};
const initialError = authErrors[new URL(Astro.request.url).searchParams.get('error') || ''] || '';
---

<BaseLayout title="Entrar · Citas">
  <div class="app-scene min-h-dvh">
    <div class="accent-line"></div>
    <div class="mx-auto flex min-h-dvh max-w-md flex-col justify-center px-4 py-10">
    <a href="/" class="brand-mark reveal mb-8 text-4xl">Citas</a>
    <div class="card reveal p-6 sm:p-8" style="transition-delay: 0.08s">
      <h1 class="brand-mark text-4xl leading-none">
        <span data-typewriter="Entrar" data-type-speed="50"></span>
      </h1>
      <p class="mt-2 text-sm text-ink-soft">Accede a tu bahía de citas.</p>

      <GoogleSignIn mode="login" enabled={googleAuth} />

      <form id="login-form" class="mt-6 space-y-4">
        <div>
          <label class="label" for="email">Email</label>
          <input class="input" id="email" name="email" type="email" required autocomplete="email" />
        </div>
        <div>
          <label class="label" for="password">Contraseña</label>
          <input class="input" id="password" name="password" type="password" required autocomplete="current-password" />
        </div>
        <p id="form-error" class:list={['text-sm font-medium text-danger', !initialError && 'hidden']} role="alert">{initialError}</p>
        <button class="btn-primary w-full !py-3" type="submit">Entrar</button>
      </form>

      <p class="mt-5 text-center text-sm text-muted">
        ¿Nuevo? <a class="font-semibold text-gold" href="/registro">Crear negocio</a>
      </p>
    </div>
    </div>
  </div>

  <script>
    const form = document.getElementById('login-form') as HTMLFormElement;
    const errorEl = document.getElementById('form-error')!;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorEl.classList.add('hidden');
      const data = Object.fromEntries(new FormData(form).entries());
      const res = await fetch('/api/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify(data),
      });
      const json = await res.json();
      if (!res.ok) {
        errorEl.textContent = json.error || 'Error al entrar';
        errorEl.classList.remove('hidden');
        return;
      }
      location.href = json.tenant?.onboardingComplete === true ? '/app' : '/app/onboarding';
    });
  </script>
</BaseLayout>
