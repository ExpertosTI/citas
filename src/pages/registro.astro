---
import BaseLayout from '../layouts/BaseLayout.astro';
import { geoFromRequest } from '../lib/geo';

const geo = geoFromRequest(Astro.request);
---

<BaseLayout title="Crear cuenta · Citas">
  <div class="app-scene min-h-dvh">
    <div class="accent-line"></div>
    <div class="mx-auto flex min-h-dvh max-w-lg flex-col justify-center px-4 py-10">
    <a href="/" class="brand-mark mb-6 text-4xl">Citas</a>
    <div class="card p-6 sm:p-8">
      <div class="geo-badge mb-4">
        <span>📍</span>
        <span id="geo-label">{geo.name} · {geo.city}</span>
      </div>
      <h1 class="brand-mark text-4xl leading-none">Registra tu negocio</h1>
      <p class="mt-2 text-sm text-ink-soft">La IA te guía para configurar servicios, precios y horario en minutos.</p>

      <form id="register-form" class="mt-6 space-y-4">
        <input type="hidden" name="country" id="country" value={geo.country} />
        <div>
          <label class="label" for="businessName">Nombre del local</label>
          <input class="input" id="businessName" name="businessName" required placeholder="Studio Nova · Salón Elegance" />
        </div>
        <div>
          <label class="label" for="ownerName">Tu nombre</label>
          <input class="input" id="ownerName" name="ownerName" required placeholder="Carlos Marte" />
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label class="label" for="email">Email</label>
            <input class="input" id="email" name="email" type="email" required placeholder="hola@tubarberia.com" />
          </div>
          <div>
            <label class="label" for="phone">Teléfono</label>
            <input class="input" id="phone" name="phone" type="tel" placeholder={geo.phonePrefix} />
          </div>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label class="label" for="city">Ciudad</label>
            <input class="input" id="city" name="city" value={geo.city} placeholder={geo.city} />
          </div>
          <div>
            <label class="label" for="password">Contraseña</label>
            <input class="input" id="password" name="password" type="password" required minlength="8" />
          </div>
        </div>
        <p id="form-error" class="hidden text-sm font-medium text-danger"></p>
        <button class="btn-primary w-full !py-3" type="submit">Crear cuenta</button>
      </form>

      <p class="mt-5 text-center text-sm text-muted">
        ¿Ya tienes cuenta? <a class="font-semibold text-gold" href="/login">Entrar</a>
      </p>
    </div>
    </div>
  </div>

  <script define:vars={{ geoCountry: geo.country, geoName: geo.name, geoCity: geo.city, geoPrefix: geo.phonePrefix }}>
    const form = document.getElementById('register-form');
    const errorEl = document.getElementById('form-error');
    const cityEl = document.getElementById('city');
    const countryEl = document.getElementById('country');
    const geoLabel = document.getElementById('geo-label');
    const phoneEl = document.getElementById('phone');

    function applyGeo(data) {
      if (!data?.country) return;
      countryEl.value = data.country;
      if (geoLabel) geoLabel.textContent = `${data.name} · ${data.city}`;
      if (cityEl && !cityEl.dataset.userEdited) cityEl.value = data.city;
      if (phoneEl && !phoneEl.value) phoneEl.placeholder = data.phonePrefix;
    }

    cityEl?.addEventListener('input', () => {
      cityEl.dataset.userEdited = '1';
    });

    fetch('/api/geo')
      .then((r) => r.json())
      .then((data) => {
        if (data.country && data.country !== geoCountry) applyGeo(data);
      })
      .catch(() => {});

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorEl.classList.add('hidden');
      const data = Object.fromEntries(new FormData(form).entries());
      const res = await fetch('/api/auth/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify(data),
      });
      const json = await res.json();
      if (!res.ok) {
        errorEl.textContent = json.error || 'Error al registrar';
        errorEl.classList.remove('hidden');
        return;
      }
      location.href = '/app/onboarding';
    });
  </script>
</BaseLayout>
