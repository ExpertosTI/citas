---
import AppLayout from '../../layouts/AppLayout.astro';
import { guardAppPage } from '../../lib/page-auth';
import { getClients } from '../../lib/store';

const auth = await guardAppPage(Astro.request);
if ('redirect' in auth) return Astro.redirect(auth.redirect);
const { tenantId } = auth;
const clients = await getClients(tenantId);
---

<AppLayout title="Clientes" active="clientes">
  <div class="mb-6 flex items-end justify-between gap-3">
    <div>
      <h1 class="brand-mark text-3xl font-bold">Clientes</h1>
      <p class="mt-1 text-sm text-ink-soft">Tu agenda de clientes del salón</p>
    </div>
    <button id="new-cli" type="button" class="btn-primary">+ Cliente</button>
  </div>

  <div class="card overflow-hidden">
    <div class="divide-y divide-border">
      {clients.length === 0 && (
        <p class="p-6 text-sm text-muted">Aún no hay clientes. Se crean al agendar citas o aquí.</p>
      )}
      {clients.map((c) => (
        <div class="flex items-center justify-between gap-3 px-4 py-3">
          <button type="button" class="min-w-0 flex-1 text-left hist-cli" data-id={c.id}>
            <p class="font-semibold">{c.name}</p>
            <p class="truncate text-sm text-muted">{c.phone || '—'} · {c.email || 'sin email'}</p>
          </button>
        </div>
      ))}
    </div>
  </div>

  <dialog id="cli-modal" class="w-[min(100%,420px)] rounded-xl border border-border bg-surface p-0 shadow-xl backdrop:bg-black/60">
    <form id="cli-form" class="p-6">
      <h2 class="brand-mark text-2xl font-bold">Nuevo cliente</h2>
      <div class="mt-4 space-y-3">
        <div>
          <label class="label" for="cli-name">Nombre</label>
          <input class="input" id="cli-name" name="name" required />
        </div>
        <div>
          <label class="label" for="cli-phone">Teléfono</label>
          <input class="input" id="cli-phone" name="phone" />
        </div>
        <div>
          <label class="label" for="cli-email">Email</label>
          <input class="input" id="cli-email" name="email" type="email" />
        </div>
      </div>
      <div class="mt-5 flex justify-end gap-2">
        <button type="button" class="btn-ghost" id="cli-cancel">Cancelar</button>
        <button type="submit" class="btn-primary">Guardar</button>
      </div>
    </form>
  </dialog>

  <dialog id="hist-modal" class="w-[min(100%,480px)] rounded-xl border border-border bg-surface p-0 shadow-xl backdrop:bg-black/60">
    <div class="p-5">
      <h2 class="brand-mark text-2xl" id="hist-title">Historial</h2>
      <div id="hist-body" class="mt-4 max-h-80 space-y-2 overflow-y-auto text-sm"></div>
      <button type="button" class="btn-ghost mt-4" id="hist-close">Cerrar</button>
    </div>
  </dialog>

  <script>
    const STATUS_LABELS = {
      pending: 'Pendiente',
      confirmed: 'Confirmada',
      received: 'Recibida',
      completed: 'Completada',
      invoiced: 'Facturada',
      cancelled: 'Cancelada',
      no_show: 'No-show',
    };

    function statusLabel(s: string) {
      return STATUS_LABELS[s as keyof typeof STATUS_LABELS] || s;
    }

    function esc(s: string) {
      return String(s || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    const modal = document.getElementById('cli-modal') as HTMLDialogElement;
    const form = document.getElementById('cli-form') as HTMLFormElement;
    document.getElementById('new-cli')?.addEventListener('click', () => modal.showModal());
    document.getElementById('cli-cancel')?.addEventListener('click', () => modal.close());
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      await fetch('/api/clients', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(Object.fromEntries(fd.entries())),
      });
      location.reload();
    });

    const histModal = document.getElementById('hist-modal') as HTMLDialogElement;
    document.querySelectorAll('.hist-cli').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = (btn as HTMLElement).dataset.id;
        const res = await fetch(`/api/clients/${id}/history`);
        const json = await res.json();
        if (!res.ok) return;
        (document.getElementById('hist-title') as HTMLElement).textContent = json.client.name;
        const body = document.getElementById('hist-body')!;
        body.innerHTML = (json.history || [])
          .map(
            (h: { startAt: string; status: string; service?: { name: string }; code?: string }) =>
              `<div class="rounded-lg border border-border p-3"><strong>${esc(new Date(h.startAt).toLocaleString('es-DO'))}</strong><br/>${esc(h.service?.name || '')} · ${esc(statusLabel(h.status))} · ${esc(h.code || '')}</div>`,
          )
          .join('') || '<p class="text-muted">Sin citas previas</p>';
        histModal.showModal();
      });
    });
    document.getElementById('hist-close')?.addEventListener('click', () => histModal.close());
  </script>
</AppLayout>
