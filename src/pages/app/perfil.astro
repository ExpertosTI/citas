---
import AppLayout from '../../layouts/AppLayout.astro';
import { COUNTRY_PRESETS } from '../../lib/geo';
import { catalogForTenant } from '../../lib/modules/tenant-modules';
import { safeTenant } from '../../lib/store';

const tenant = safeTenant(Astro.locals.tenant!);
const modules = catalogForTenant(Astro.locals.tenant!);
const moduleDisabled = Astro.url.searchParams.get('module') === 'disabled';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://citas.renace.tech').replace(/\/$/, '');
const publicUrl = `${siteUrl}/s/${tenant.slug}`;
const logoPreview = tenant.logoUrl?.startsWith('http') ? tenant.logoUrl : `/api/logo/${tenant.id}?t=${Date.now()}`;
const closedDaysStr = (tenant.closedDays || []).join(', ');
const closedWeekdaysStr = (tenant.closedWeekdays || []).join(', ');
const countries = Object.values(COUNTRY_PRESETS);
const currencies = [...new Set(countries.map((c) => c.currency))];
---

<AppLayout title="Perfil" active="perfil">
  <div class="mb-6">
    <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-mustard-deep">Tu negocio</p>
    <h1 class="font-display mt-1 text-3xl font-semibold tracking-tight text-ink">Perfil del local</h1>
    <p class="mt-1 text-sm text-muted">Logo, horarios, datos de contacto y enlace público</p>
    {moduleDisabled && (
      <p class="mt-2 rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-900">
        Ese módulo no está activo en tu cuenta. Actívalo abajo en <strong>Módulos</strong>.
      </p>
    )}
  </div>

  <div class="card mb-4 flex flex-wrap items-center justify-between gap-4 p-4">
    <div class="min-w-0 flex-1">
      <p class="text-[10px] font-bold uppercase tracking-[0.14em] text-muted">Enlace público</p>
      <a class="mt-1 block break-all text-sm font-semibold text-navy hover:text-mustard-deep" href={publicUrl} target="_blank" rel="noreferrer">{publicUrl}</a>
    </div>
    <div class="flex gap-2">
      <button type="button" id="copy-link" class="btn-ghost !text-xs">Copiar link</button>
      <a id="wa-share" class="btn-primary !text-xs" href="#" target="_blank" rel="noreferrer">WhatsApp</a>
    </div>
  </div>

  <div class="card mb-4 p-5">
    <p class="label">Logo del local</p>
    <div class="flex flex-wrap items-center gap-4">
      <img
        id="logo-preview"
        src={logoPreview}
        alt="Logo"
        class="h-20 w-20 rounded-xl border border-border object-cover bg-surface-2"
        onerror="this.src='';this.classList.add('hidden')"
      />
      <form id="logo-form" class="flex flex-col gap-2">
        <input class="input !max-w-xs" type="file" name="logo" accept="image/png,image/jpeg,image/webp" />
        <button type="submit" class="btn-primary !py-2 !text-xs w-fit">Subir logo</button>
      </form>
    </div>
  </div>

  <div class="card mb-4 p-5" id="modules-panel">
    <div class="mb-4">
      <p class="label">Módulos</p>
      <p class="text-xs text-muted">Activa o desactiva funciones según el tipo de negocio de cada cliente.</p>
    </div>
    <div class="space-y-3">
      {modules.map((mod) => (
        <div class="flex flex-wrap items-center justify-between gap-3 rounded-xl border border-border bg-surface-2 px-4 py-3">
          <div class="min-w-0">
            <p class="text-sm font-semibold text-ink">
              <span class="mr-1.5" aria-hidden="true">{mod.icon}</span>
              {mod.label}
            </p>
            <p class="text-xs text-muted">{mod.description}</p>
          </div>
          <button
            type="button"
            class:list={[
              'btn-sm shrink-0',
              mod.enabled ? 'btn-ghost' : 'btn-primary',
            ]}
            data-module-toggle
            data-module-id={mod.id}
            data-enabled={mod.enabled ? '1' : '0'}
          >
            {mod.enabled ? 'Desactivar' : 'Activar'}
          </button>
        </div>
      ))}
    </div>
  </div>

  <form id="profile-form" class="card space-y-4 p-5 sm:p-6">
    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <label class="label" for="businessName">Nombre del local</label>
        <input class="input" id="businessName" name="businessName" value={tenant.businessName} required />
      </div>
      <div>
        <label class="label" for="ownerName">Responsable</label>
        <input class="input" id="ownerName" name="ownerName" value={tenant.ownerName} required />
      </div>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <label class="label" for="slug">Slug (URL)</label>
        <input class="input" id="slug" name="slug" value={tenant.slug} required />
      </div>
      <div>
        <label class="label" for="phone">Teléfono</label>
        <input class="input" id="phone" name="phone" value={tenant.phone} />
      </div>
    </div>
    <div class="grid gap-4 sm:grid-cols-3">
      <div>
        <label class="label" for="country">País</label>
        <select class="input" id="country" name="country">
          {countries.map((c) => (
            <option value={c.code} selected={c.code === tenant.country}>{c.name}</option>
          ))}
        </select>
      </div>
      <div>
        <label class="label" for="currency">Moneda</label>
        <select class="input" id="currency" name="currency">
          {currencies.map((cur) => (
            <option value={cur} selected={cur === tenant.currency}>{cur}</option>
          ))}
        </select>
      </div>
      <div>
        <label class="label" for="timezone">Zona horaria</label>
        <input class="input" id="timezone" name="timezone" value={tenant.timezone} placeholder="America/Santo_Domingo" />
      </div>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <label class="label" for="whatsapp">WhatsApp</label>
        <input class="input" id="whatsapp" name="whatsapp" value={tenant.whatsapp} placeholder="8095551234" />
      </div>
      <div>
        <label class="label" for="instagram">Instagram</label>
        <input class="input" id="instagram" name="instagram" value={tenant.instagram} placeholder="tubarberia" />
      </div>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <label class="label" for="city">Ciudad</label>
        <input class="input" id="city" name="city" value={tenant.city} />
      </div>
      <div>
        <label class="label" for="address">Dirección</label>
        <input class="input" id="address" name="address" value={tenant.address} />
      </div>
    </div>
    <div>
      <label class="label" for="bio">Bio</label>
      <textarea class="input" id="bio" name="bio" rows="3">{tenant.bio}</textarea>
    </div>
    <div class="grid gap-4 sm:grid-cols-3">
      <div>
        <label class="label" for="openHour">Abre</label>
        <input class="input" id="openHour" name="openHour" type="number" min="0" max="23" value={tenant.openHour} />
      </div>
      <div>
        <label class="label" for="closeHour">Cierra</label>
        <input class="input" id="closeHour" name="closeHour" type="number" min="1" max="24" value={tenant.closeHour} />
      </div>
      <div>
        <label class="label" for="accentColor">Color marca</label>
        <input class="input" id="accentColor" name="accentColor" type="color" value={tenant.accentColor} />
      </div>
    </div>
    <div class="grid gap-4 sm:grid-cols-3">
      <div>
        <label class="label" for="lunchStartHour">Almuerzo desde</label>
        <input class="input" id="lunchStartHour" name="lunchStartHour" type="number" min="0" max="23" value={tenant.lunchStartHour} />
      </div>
      <div>
        <label class="label" for="lunchEndHour">Almuerzo hasta</label>
        <input class="input" id="lunchEndHour" name="lunchEndHour" type="number" min="0" max="24" value={tenant.lunchEndHour} />
      </div>
      <div>
        <label class="label" for="slotBufferMin">Buffer (min)</label>
        <input class="input" id="slotBufferMin" name="slotBufferMin" type="number" min="0" max="60" value={tenant.slotBufferMin} />
      </div>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <label class="label" for="closedWeekdays">Días cerrados (0=Dom, 1=Lun…)</label>
        <input class="input" id="closedWeekdays" name="closedWeekdays" value={closedWeekdaysStr} placeholder="0" />
      </div>
      <div>
        <label class="label" for="closedDays">Fechas cerradas (YYYY-MM-DD, coma)</label>
        <input class="input" id="closedDays" name="closedDays" value={closedDaysStr} placeholder="2026-12-25" />
      </div>
    </div>
    <p id="profile-msg" class="hidden text-sm font-medium text-mustard-deep"></p>
    <div class="flex flex-wrap gap-3">
      <button type="submit" class="btn-primary">Guardar perfil</button>
      <a href="/app/onboarding?open=1" class="btn-ghost btn-sm">Abrir asistente</a>
    </div>
  </form>

  <script type="module" define:vars={{ publicUrl, whatsapp: tenant.whatsapp || tenant.phone }}>
    import { toast } from '../../scripts/ui-feedback.js';

    document.getElementById('copy-link')?.addEventListener('click', async () => {
      await navigator.clipboard.writeText(publicUrl);
      toast('Enlace copiado', 'success');
    });
    const wa = document.getElementById('wa-share');
    if (wa instanceof HTMLAnchorElement) {
      const phone = String(whatsapp || '').replace(/\D/g, '');
      wa.href = phone
        ? `https://wa.me/${phone}?text=${encodeURIComponent(`Reserva tu cita: ${publicUrl}`)}`
        : '#';
    }

    document.getElementById('country')?.addEventListener('change', (e) => {
      const code = e.target.value;
      const presets = {
        DO: { timezone: 'America/Santo_Domingo', currency: 'DOP' },
        PR: { timezone: 'America/Puerto_Rico', currency: 'USD' },
        VE: { timezone: 'America/Caracas', currency: 'USD' },
        CO: { timezone: 'America/Bogota', currency: 'COP' },
        MX: { timezone: 'America/Mexico_City', currency: 'MXN' },
        US: { timezone: 'America/New_York', currency: 'USD' },
        ES: { timezone: 'Europe/Madrid', currency: 'EUR' },
      };
      const p = presets[code];
      if (p) {
        const tz = document.getElementById('timezone');
        const cur = document.getElementById('currency');
        if (tz) tz.value = p.timezone;
        if (cur) cur.value = p.currency;
      }
    });

    document.querySelectorAll('[data-module-toggle]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const moduleId = btn.getAttribute('data-module-id');
        const enabled = btn.getAttribute('data-enabled') !== '1';
        btn.disabled = true;
        const res = await fetch('/api/modules', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ moduleId, enabled }),
        });
        const json = await res.json();
        btn.disabled = false;
        if (res.ok) {
          toast(enabled ? 'Módulo activado' : 'Módulo desactivado', 'success');
          setTimeout(() => location.reload(), 500);
        } else {
          toast(json.error || 'No se pudo cambiar el módulo', 'error');
        }
      });
    });

    document.getElementById('logo-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const fd = new FormData(form);
      const res = await fetch('/api/logo', { method: 'POST', body: fd });
      const json = await res.json();
      if (res.ok) {
        const img = document.getElementById('logo-preview');
        if (img) {
          img.classList.remove('hidden');
          img.src = `${json.logoUrl}?t=${Date.now()}`;
        }
        toast('Logo actualizado', 'success');
      } else {
        toast(json.error || 'No se pudo subir el logo', 'error');
      }
    });

    const form = document.getElementById('profile-form');
    const msg = document.getElementById('profile-msg');
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const payload = Object.fromEntries(fd.entries());
      payload.openHour = Number(payload.openHour);
      payload.closeHour = Number(payload.closeHour);
      payload.lunchStartHour = Number(payload.lunchStartHour);
      payload.lunchEndHour = Number(payload.lunchEndHour);
      payload.slotBufferMin = Number(payload.slotBufferMin);
      const res = await fetch('/api/profile', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const json = await res.json();
      if (res.ok) {
        toast('Perfil guardado', 'success');
        setTimeout(() => location.reload(), 600);
      } else {
        toast(json.error || 'No se pudo guardar', 'error');
      }
    });
  </script>
</AppLayout>
