---
import AppLayout from '../../layouts/AppLayout.astro';
import { guardAppPage } from '../../lib/page-auth';
import { APPOINTMENT_COLORS, getServices } from '../../lib/store';

const auth = await guardAppPage(Astro.request);
if ('redirect' in auth) return Astro.redirect(auth.redirect);
const { tenantId } = auth;
const services = await getServices(tenantId);
---

<AppLayout title="Servicios" active="servicios">
  <div class="mb-6 flex items-end justify-between gap-3">
    <div>
      <h1 class="brand-mark text-3xl font-bold">Servicios</h1>
      <p class="mt-1 text-sm text-ink-soft">Catálogo del salón con color en la bahía</p>
    </div>
    <button id="new-svc" type="button" class="btn-primary">+ Servicio</button>
  </div>

  <div class="grid gap-3 sm:grid-cols-2">
    {services.map((s) => {
      const color = APPOINTMENT_COLORS.find((c) => c.id === s.color)?.hex || '#e8b923';
      return (
        <article class="card flex items-start gap-4 p-4" data-id={s.id}>
          <span class="mt-1 h-10 w-10 shrink-0 rounded-xl" style={`background:${color}`}></span>
          <div class="min-w-0 flex-1">
            <h2 class="font-bold">{s.name}</h2>
            <p class="text-sm text-muted">{s.durationMin} min · ${s.price}</p>
            <div class="mt-3 flex gap-2">
              <button type="button" class="btn-ghost !px-3 !py-1.5 !text-xs edit-svc"
                data-id={s.id}
                data-name={s.name}
                data-duration={s.durationMin}
                data-price={s.price}
                data-color={s.color}
              >Editar</button>
              <button type="button" class="btn-ghost !px-3 !py-1.5 !text-xs text-red-600 del-svc" data-id={s.id}>Eliminar</button>
            </div>
          </div>
        </article>
      );
    })}
  </div>

  <dialog id="svc-modal" class="w-[min(100%,420px)] rounded-xl border border-border bg-surface p-0 shadow-xl backdrop:bg-black/60">
    <form id="svc-form" class="p-6">
      <h2 class="brand-mark text-2xl font-bold" id="svc-title">Nuevo servicio</h2>
      <input type="hidden" name="id" id="svc-id" />
      <div class="mt-4 space-y-3">
        <div>
          <label class="label" for="svc-name">Nombre</label>
          <input class="input" id="svc-name" name="name" required />
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="label" for="svc-duration">Minutos</label>
            <input class="input" id="svc-duration" name="durationMin" type="number" min="5" step="5" value="30" required />
          </div>
          <div>
            <label class="label" for="svc-price">Precio</label>
            <input class="input" id="svc-price" name="price" type="number" min="0" step="0.01" value="20" required />
          </div>
        </div>
        <div>
          <label class="label" for="svc-color">Color</label>
          <select class="input" id="svc-color" name="color">
            {APPOINTMENT_COLORS.map((c) => <option value={c.id}>{c.label}</option>)}
          </select>
        </div>
      </div>
      <div class="mt-5 flex justify-end gap-2">
        <button type="button" class="btn-ghost" id="svc-cancel">Cancelar</button>
        <button type="submit" class="btn-primary">Guardar</button>
      </div>
    </form>
  </dialog>

  <script>
    import { confirmAction } from '../../scripts/ui-feedback.js';

    const modal = document.getElementById('svc-modal') as HTMLDialogElement;
    const form = document.getElementById('svc-form') as HTMLFormElement;

    function openNew() {
      (document.getElementById('svc-title') as HTMLElement).textContent = 'Nuevo servicio';
      (document.getElementById('svc-id') as HTMLInputElement).value = '';
      form.reset();
      modal.showModal();
    }

    document.getElementById('new-svc')?.addEventListener('click', openNew);
    document.getElementById('svc-cancel')?.addEventListener('click', () => modal.close());

    document.querySelectorAll('.edit-svc').forEach((btn) => {
      btn.addEventListener('click', () => {
        const el = btn as HTMLElement;
        (document.getElementById('svc-title') as HTMLElement).textContent = 'Editar servicio';
        (document.getElementById('svc-id') as HTMLInputElement).value = el.dataset.id || '';
        (document.getElementById('svc-name') as HTMLInputElement).value = el.dataset.name || '';
        (document.getElementById('svc-duration') as HTMLInputElement).value = el.dataset.duration || '30';
        (document.getElementById('svc-price') as HTMLInputElement).value = el.dataset.price || '0';
        (document.getElementById('svc-color') as HTMLSelectElement).value = el.dataset.color || 'gold';
        modal.showModal();
      });
    });

    document.querySelectorAll('.del-svc').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const ok = await confirmAction('¿Eliminar servicio?', {
          confirmLabel: 'Eliminar',
          cancelLabel: 'Cancelar',
        });
        if (!ok) return;
        const id = (btn as HTMLElement).dataset.id;
        await fetch(`/api/services?id=${encodeURIComponent(id || '')}`, { method: 'DELETE' });
        location.reload();
      });
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const payload: Record<string, unknown> = {
        name: fd.get('name'),
        durationMin: Number(fd.get('durationMin')),
        price: Number(fd.get('price')),
        color: fd.get('color'),
      };
      const id = String(fd.get('id') || '');
      if (id) payload.id = id;
      await fetch('/api/services', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      location.reload();
    });
  </script>
</AppLayout>
