---
import OnboardingLayout from '../../layouts/OnboardingLayout.astro';
import { isGeminiConfigured } from '../../lib/gemini';
import { initialAssistantMessage } from '../../lib/onboarding-ai';
import { SETUP_PHASES, publicLogoPreview } from '../../lib/setup-phases';
import { getServices, safeTenant } from '../../lib/store';

const tenant = Astro.locals.tenant!;
const t = safeTenant(tenant);
const isReopen = Astro.url.searchParams.has('open');
const geminiOk = isGeminiConfigured();
const greeting = initialAssistantMessage(tenant);
const currencyLabel = t.currency === 'DOP' ? 'RD$' : t.currency === 'USD' ? 'USD' : t.currency;
const firstName = tenant.ownerName.split(' ')[0];
const services = await getServices(tenant.id);
const serviceCount = services.filter((s) => s.active).length;
const logoUrl = publicLogoPreview(tenant);
---

<OnboardingLayout title={`Bienvenido · ${t.businessName}`} businessName={t.businessName}>
  <div
    id="onboarding-root"
    class="w-full max-w-lg"
    data-greeting={greeting}
    data-gemini={geminiOk ? '1' : '0'}
    data-currency={currencyLabel}
    data-business={t.businessName}
    data-reopen={isReopen ? '1' : '0'}
    data-logo-url={logoUrl}
    data-service-count={serviceCount}
  >
    <div id="onboarding-main">
      <div class="onboarding-hero">
        <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-mustard-deep">
          Configuración guiada
        </p>
        <h1 class="font-display mt-2 text-3xl font-semibold tracking-tight text-ink sm:text-4xl">
          {isReopen ? 'Ajusta tu negocio' : `Armemos ${t.businessName}`}
        </h1>
        <p class="mt-2 text-sm text-muted">
          Chat inteligente · logo, servicios, horario y contacto en minutos.
        </p>
        <p id="gemini-badge" class:list={['config-gemini-badge mt-2', geminiOk && 'hidden']}>
          Modo básico (sin Gemini)
        </p>

        <div class="setup-phases" id="onboarding-phases">
          <p class="setup-phases__label" data-phase-label>{SETUP_PHASES[0].short}</p>
          <div class="setup-phases__track">
            {SETUP_PHASES.map((p) => (
              <span
                class="setup-phases__step"
                data-phase={p.id}
                data-phase-label={p.short}
                title={p.label}
              />
            ))}
          </div>
        </div>
      </div>

      <div class="onboarding-chat glass mt-5 overflow-hidden rounded-[1.75rem]">
        <div id="chat-messages" class="onboarding-chat__messages"></div>
        <div id="setup-preview" class="onboarding-chat__preview hidden"></div>
        <div id="chat-chips" class="chat-chips hidden"></div>
        <form id="chat-form" class="onboarding-chat__input-row config-composer">
          <input type="file" id="logo-file" class="sr-only" accept="image/png,image/jpeg,image/webp" />
          <button type="button" id="logo-attach" class="config-composer__attach" aria-label="Subir logo PNG">
            📎
          </button>
          <input
            id="chat-input"
            class="input"
            type="text"
            placeholder="Escribe o elige una sugerencia…"
            autocomplete="off"
          />
          <button type="submit" class="btn-primary btn-sm">Enviar</button>
        </form>
      </div>

      <div class="mt-4 flex flex-wrap justify-center gap-3">
        <button id="apply-btn" type="button" class="btn-accent hidden">Aplicar y abrir bahía</button>
        {!isReopen && (
          <button id="skip-btn" type="button" class="btn-ghost btn-sm">Saltar · configurar manual</button>
        )}
      </div>
    </div>

    <div id="onboarding-done" class="onboarding-success hidden">
      <div class="onboarding-success__icon">✓</div>
      <h2 class="font-display text-2xl font-semibold text-ink">¡Listo!</h2>
      <p class="mt-2 text-sm text-muted">Tu negocio está configurado. Abriendo bahía…</p>
    </div>
  </div>

  <script>
    import { createConfigChat } from '../../scripts/config-chat.js';

    const root = document.getElementById('onboarding-root')!;
    const mainEl = document.getElementById('onboarding-main')!;
    const doneEl = document.getElementById('onboarding-done')!;

    createConfigChat({
      mode: 'onboarding',
      root,
      messagesEl: document.getElementById('chat-messages')!,
      previewEl: document.getElementById('setup-preview')!,
      formEl: document.getElementById('chat-form') as HTMLFormElement,
      inputEl: document.getElementById('chat-input') as HTMLInputElement,
      applyBtn: document.getElementById('apply-btn')!,
      chipsEl: document.getElementById('chat-chips')!,
      phasesEl: document.getElementById('onboarding-phases')!,
      fileInput: document.getElementById('logo-file') as HTMLInputElement,
      attachBtn: document.getElementById('logo-attach')!,
      geminiBadge: document.getElementById('gemini-badge')!,
      currency: root.dataset.currency || 'RD$',
      businessName: root.dataset.business || '',
      greeting: root.dataset.greeting || '',
      onSuccess: () => {
        mainEl.classList.add('hidden');
        doneEl.classList.remove('hidden');
        setTimeout(() => {
          location.href = '/app';
        }, 1800);
      },
      onSkip: () => {
        location.href = '/app';
      },
    });
  </script>
</OnboardingLayout>
