---
import AppLayout from '../../layouts/AppLayout.astro';
import TimeInput12 from '../../components/TimeInput12.astro';
import { buildDayBoard } from '../../lib/day-board';
import { tenantHasModule } from '../../lib/modules/tenant-modules';
import { adminServiceMeta } from '../../lib/service-display';
import { formatIsoTime, formatTimeHm } from '../../lib/time-12h';
import { getBoardDay, getBoardWeek, getDashboardStats } from '../../lib/store';

const tenantId = Astro.locals.tenantId!;
const tenant = Astro.locals.tenant!;
const showWaitlist = tenantHasModule(tenant, 'waitlist');

const today = new Date();
const todayStr = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, '0')}-${String(today.getDate()).padStart(2, '0')}`;
const qDate = Astro.url.searchParams.get('date') || '';
const dateStr = /^\d{4}-\d{2}-\d{2}$/.test(qDate) ? qDate : todayStr;

const [board, stats, week] = await Promise.all([
  getBoardDay(tenantId, dateStr),
  getDashboardStats(tenantId),
  getBoardWeek(tenantId, todayStr),
]);

const daySlots = buildDayBoard(tenant, dateStr, board.appointments);
const visibleSlots = daySlots.filter((s) => s.kind !== 'past');
const bookedCount = visibleSlots.filter((s) => s.kind === 'booked').length;
const dayPendingCount = visibleSlots.filter(
  (s) => s.kind === 'booked' && s.appointment?.status === 'pending',
).length;
const currency = board.tenant?.currency === 'DOP' ? 'RD$' : board.tenant?.currency || 'RD$';
const defaultServiceId = board.services[0]?.id || '';
const isToday = dateStr === todayStr;

function formatWhen(iso: string) {
  return formatIsoTime(iso, board.tenant?.timezone);
}

function aptDay(iso: string) {
  const d = new Date(iso);
  return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
}

const pendingElsewhere = stats.pendingList.filter((a) => aptDay(a.startAt) !== dateStr);
---

<AppLayout title="Bahía" active="bahia">
  <div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="font-display text-2xl font-bold tracking-tight text-ink sm:text-3xl">Bahía</h1>
      <p class="mt-0.5 text-sm text-muted">
        {isToday ? 'Hoy' : dateStr}
        {bookedCount > 0 && ` · ${bookedCount} cita${bookedCount === 1 ? '' : 's'}`}
        {dayPendingCount > 0 && ` · ${dayPendingCount} pendiente${dayPendingCount === 1 ? '' : 's'}`}
      </p>
    </div>
    <div class="flex w-full flex-wrap items-stretch gap-2 sm:w-auto">
      <input id="bay-date" class="input !w-full !rounded-lg sm:!w-auto" type="date" value={dateStr} />
      {showWaitlist && stats.waitlistCount > 0 && (
        <a href="/app/waitlist" class="btn-ghost btn-sm">Espera ({stats.waitlistCount})</a>
      )}
      <button id="new-apt-btn" type="button" class="btn-primary btn-sm">+ Cita</button>
    </div>
  </div>

  <div class="mb-4 flex gap-1.5 overflow-x-auto pb-1">
    {week.map((d) => (
      <a
        href={`/app?date=${d.date}`}
        class:list={[
          'bay-week-chip',
          d.date === dateStr && 'bay-week-chip--active',
        ]}
      >
        <span class="bay-week-chip__day">{d.date?.slice(5) ?? '—'}</span>
        <span class="bay-week-chip__count">{d.count}</span>
      </a>
    ))}
  </div>

  {pendingElsewhere.length > 0 && (
    <div class="bay-pending-strip mb-4">
      <div class="bay-pending-strip__head">
        <span class="bay-pending-strip__badge">{pendingElsewhere.length}</span>
        <span class="bay-pending-strip__title">Pendientes</span>
      </div>
      <div class="bay-pending-strip__list">
        {pendingElsewhere.slice(0, 6).map((a) => (
          <div class="bay-pending-chip">
            <div class="bay-pending-chip__info">
              <p class="bay-pending-chip__name">{a.client?.name || 'Cliente'}</p>
              <p class="bay-pending-chip__meta">{a.service?.name} · {formatWhen(a.startAt)}</p>
            </div>
            <div class="bay-pending-chip__actions">
              <button type="button" class="bay-pending-chip__ok cmd-act" data-id={a.id} data-action="confirmed" data-notify="1" aria-label="Confirmar">✓</button>
              <button type="button" class="bay-pending-chip__no cmd-act" data-id={a.id} data-action="cancelled" data-notify="1" aria-label="Rechazar">✕</button>
            </div>
          </div>
        ))}
      </div>
    </div>
  )}

  <div id="bay-board" class="scroll-mt-20 cmd-board">
      {visibleSlots.length === 0 && (
        <p class="py-10 text-center text-sm text-muted">Sin horarios para este día.</p>
      )}
      {visibleSlots.map((slot) => (
        <div class="cmd-row" style={slot.span > 1 ? `min-height:${slot.span * 3.75}rem` : undefined}>
          <div class="cmd-row__time">{formatTimeHm(slot.time)}</div>

          {slot.kind === 'free' && (
            <button
              type="button"
              class="cmd-slot cmd-slot--free cmd-free-slot"
              data-time={slot.time}
              data-start={slot.startAt}
            >
              <span class="cmd-slot__label">+ Reservar</span>
            </button>
          )}

          {slot.kind === 'lunch' && (
            <div class="cmd-slot cmd-slot--lunch">
              <span>Almuerzo</span>
            </div>
          )}

          {slot.kind === 'booked' && slot.appointment && (
            <div
              class:list={[
                'cmd-slot cmd-slot--booked',
                `is-${slot.appointment.status}`,
              ]}
              style={slot.span > 1 ? `min-height:${slot.span * 3.5 - 0.25}rem` : undefined}
              data-id={slot.appointment.id}
            >
              <div class="cmd-slot__row">
                <div class="cmd-slot__info">
                  <p class="cmd-slot__client">{slot.appointment.client?.name || 'Cliente'}</p>
                  <p class="cmd-slot__meta">{slot.appointment.service?.name}</p>
                </div>
                <div class="cmd-slot__actions">
                {slot.appointment.status === 'pending' && (
                  <>
                    <button type="button" class="btn-action btn-action--confirm cmd-act" data-id={slot.appointment.id} data-action="confirmed" data-notify="1">Confirmar</button>
                    <button type="button" class="btn-action btn-action--danger cmd-act" data-id={slot.appointment.id} data-action="cancelled" data-notify="1">Rechazar</button>
                  </>
                )}
                {slot.appointment.status === 'confirmed' && (
                  <>
                    <button type="button" class="btn-action btn-action--confirm cmd-act" data-id={slot.appointment.id} data-action="received">Recibir</button>
                    <button type="button" class="btn-action btn-action--confirm cmd-act" data-id={slot.appointment.id} data-action="completed">Hecho</button>
                    <details class="cmd-slot__more">
                      <summary class="cmd-slot__more-btn" aria-label="Más acciones">···</summary>
                      <div class="cmd-slot__more-menu">
                        <button type="button" class="cmd-act-reschedule" data-id={slot.appointment.id} data-time={slot.time}>Cambiar hora</button>
                        <button type="button" class="cmd-act" data-id={slot.appointment.id} data-action="no_show">No-show</button>
                        <button type="button" class="cmd-act" data-id={slot.appointment.id} data-action="cancelled" data-notify="1">Cancelar</button>
                      </div>
                    </details>
                  </>
                )}
                {slot.appointment.status === 'received' && (
                  <>
                    <button type="button" class="btn-action btn-action--confirm cmd-act" data-id={slot.appointment.id} data-action="completed">Hecho</button>
                    <button type="button" class="cmd-act-reschedule cmd-slot__link-btn" data-id={slot.appointment.id} data-time={slot.time}>Hora</button>
                  </>
                )}
                {slot.appointment.status === 'completed' && (
                  <button type="button" class="btn-action cmd-act" data-id={slot.appointment.id} data-action="invoiced">Facturar</button>
                )}
                </div>
              </div>
            </div>
          )}
        </div>
      ))}
  </div>

  <dialog id="apt-modal" class="apt-dialog">
    <form id="apt-form" class="p-5 sm:p-6">
      <h2 class="font-display text-xl font-semibold text-ink">Nueva cita</h2>
      <div class="mt-4 space-y-3">
        <div>
          <label class="label" for="clientName">Cliente</label>
          <input class="input" id="clientName" name="clientName" list="clients-list" required />
          <datalist id="clients-list">
            {board.clients.map((c) => <option value={c.name} />)}
          </datalist>
        </div>
        <div class="grid min-w-0 grid-cols-1 gap-3 sm:grid-cols-2">
          <div class="min-w-0">
            <label class="label" for="clientPhone">Teléfono</label>
            <input class="input" id="clientPhone" name="clientPhone" inputmode="tel" autocomplete="tel" />
          </div>
          <div class="min-w-0">
            <label class="label" for="clientEmail">Email</label>
            <input class="input" id="clientEmail" name="clientEmail" type="email" autocomplete="email" />
          </div>
        </div>
        <div>
          <label class="label" for="serviceId">Servicio</label>
          <select class="input" id="serviceId" name="serviceId" required>
            {board.services.map((s) => (
              <option value={s.id} selected={s.id === defaultServiceId}>
                {s.name} · {adminServiceMeta(s, board.tenant?.currency || 'DOP')}
              </option>
            ))}
          </select>
        </div>
        <div class="grid min-w-0 grid-cols-1 gap-3 sm:grid-cols-2">
          <div class="min-w-0">
            <label class="label" for="aptDate">Fecha</label>
            <input class="input" id="aptDate" name="aptDate" type="date" value={dateStr} required />
          </div>
          <div class="min-w-0">
            <TimeInput12 id="aptTime" name="aptTime" value="10:00" label="Hora" required />
          </div>
        </div>
        <div>
          <label class="label" for="notes">Notas</label>
          <textarea class="input" id="notes" name="notes" rows="2"></textarea>
        </div>
        <p id="apt-error" class="hidden text-sm font-medium text-red-600"></p>
      </div>
      <div class="mt-5 flex flex-col-reverse gap-2 sm:flex-row sm:justify-end">
        <button type="button" class="btn-ghost w-full sm:w-auto" id="apt-cancel">Cancelar</button>
        <button type="submit" class="btn-primary w-full sm:w-auto">Guardar</button>
      </div>
    </form>
  </dialog>

  <script>
    import { confirmAction, promptTime12, toast } from '../../scripts/ui-feedback.js';
    import { bindTime12hFields } from '../../lib/time-12h.ts';

    const bayDate = document.getElementById('bay-date');
    const modal = document.getElementById('apt-modal');
    const form = document.getElementById('apt-form');
    const errorEl = document.getElementById('apt-error');
    const dateStr = document.getElementById('bay-date')?.value || '';

    bayDate?.addEventListener('change', () => {
      location.href = `/app?date=${bayDate.value}`;
    });

    function openModal(time) {
      if (time) {
        const wrap = document.getElementById('aptTime')?.closest('.time-12h');
        if (wrap) {
          const parts = time.split(':');
          const h24 = Number(parts[0]);
          const m = parts[1] || '00';
          const hSel = wrap.querySelector('[data-time-part="h"]');
          const mSel = wrap.querySelector('[data-time-part="m"]');
          const pSel = wrap.querySelector('[data-time-part="period"]');
          let h12 = h24 % 12;
          if (h12 === 0) h12 = 12;
          const period = h24 >= 12 ? 'PM' : 'AM';
          if (hSel instanceof HTMLSelectElement) hSel.value = String(h12);
          if (mSel instanceof HTMLSelectElement) mSel.value = m;
          if (pSel instanceof HTMLSelectElement) pSel.value = period;
          bindTime12hFields(wrap);
        }
      }
      modal?.showModal();
    }

    bindTime12hFields(form);

    document.getElementById('new-apt-btn')?.addEventListener('click', () => openModal('10:00'));
    document.getElementById('apt-cancel')?.addEventListener('click', () => modal?.close());

    (function prefillFromUrl() {
      const p = new URLSearchParams(location.search);
      if (p.get('newApt') !== '1') return;
      const set = (id, val) => {
        const el = document.getElementById(id);
        if (el && val) (el as HTMLInputElement).value = val;
      };
      set('clientName', p.get('clientName') || '');
      set('clientPhone', p.get('clientPhone') || '');
      set('clientEmail', p.get('clientEmail') || '');
      set('aptDate', p.get('date') || dateStr);
      const svc = document.getElementById('serviceId') as HTMLSelectElement | null;
      if (svc && p.get('serviceId')) svc.value = p.get('serviceId')!;
      openModal('10:00');
    })();

    document.querySelectorAll('.cmd-free-slot').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const aptDateEl = document.getElementById('aptDate');
        if (aptDateEl && bayDate?.value) aptDateEl.value = bayDate.value;
        openModal(btn.dataset.time || '10:00');
      });
    });

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      bindTime12hFields(form);
      errorEl?.classList.add('hidden');
      const fd = new FormData(form);
      const aptDate = String(fd.get('aptDate'));
      const aptTime = String(fd.get('aptTime'));

      const res = await fetch('/api/appointments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          clientName: fd.get('clientName'),
          clientPhone: fd.get('clientPhone'),
          clientEmail: fd.get('clientEmail'),
          serviceId: fd.get('serviceId'),
          aptDate,
          aptTime,
          notes: fd.get('notes'),
          notify: true,
        }),
      });
      const json = await res.json();
      if (!res.ok) {
        if (errorEl) errorEl.textContent = json.error || 'Error';
        errorEl?.classList.remove('hidden');
        return;
      }
      location.reload();
    });

    async function patchAppointment(id, body, btn) {
      if (btn) btn.classList.add('is-busy');
      const res = await fetch(`/api/appointments/${id}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      if (btn) btn.classList.remove('is-busy');
      if (!res.ok) {
        const json = await res.json();
        toast(json.error || 'No se pudo actualizar', 'error');
        return false;
      }
      toast('Cita actualizada', 'success');
      setTimeout(() => location.reload(), 400);
      return true;
    }

    document.querySelectorAll('.cmd-act').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const id = btn.dataset.id;
        const action = btn.dataset.action;
        if (!id || !action || btn.classList.contains('is-busy')) return;
        const payload = { status: action };
        if (btn.dataset.notify === '1') payload.notify = true;
        if (action === 'cancelled') {
          const ok = await confirmAction('¿Cancelar esta cita?', {
            confirmLabel: 'Sí, cancelar',
            cancelLabel: 'No',
          });
          if (!ok) return;
        }
        await patchAppointment(id, payload, btn);
      });
    });

    document.querySelectorAll('.cmd-act-reschedule').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        if (btn.classList.contains('is-busy')) return;
        const id = btn.dataset.id;
        const time = await promptTime12('Nueva hora', btn.dataset.time || '10:00');
        if (!time || !id) return;
        const date = bayDate?.value || dateStr;
        await patchAppointment(id, { aptDate: date, aptTime: time, notify: true }, btn);
      });
    });

    document.querySelectorAll('.cmd-slot__more').forEach((details) => {
      details.addEventListener('toggle', () => {
        if (!details.open) return;
        document.querySelectorAll('.cmd-slot__more[open]').forEach((other) => {
          if (other !== details) other.removeAttribute('open');
        });
      });
    });
  </script>
</AppLayout>
