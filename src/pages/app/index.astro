---
import AppLayout from '../../layouts/AppLayout.astro';
import { tenantIdFromRequest } from '../../lib/auth';
import { getBoardDay, getBoardWeek, getDashboardStats } from '../../lib/store';
import { cutStyleLabel } from '../../lib/cut-styles';

const tenantId = tenantIdFromRequest(Astro.request)!;
const today = new Date();
const todayStr = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, '0')}-${String(today.getDate()).padStart(2, '0')}`;
const qDate = Astro.url.searchParams.get('date') || '';
const dateStr = /^\d{4}-\d{2}-\d{2}$/.test(qDate) ? qDate : todayStr;
const [board, stats, week] = await Promise.all([
  getBoardDay(tenantId, dateStr),
  getDashboardStats(tenantId),
  getBoardWeek(tenantId, todayStr),
]);
const openHour = board.tenant?.openHour ?? 9;
const closeHour = board.tenant?.closeHour ?? 19;
const hours = Array.from({ length: closeHour - openHour }, (_, i) => openHour + i);
---

<AppLayout title="Bahía de citas" active="bahia">
  <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h1 class="brand-mark text-3xl font-bold">Bahía de citas</h1>
      <p class="mt-1 text-sm text-ink-soft">Vista del día con colores de peluquería</p>
    </div>
    <div class="flex flex-wrap items-center gap-2">
      <input id="bay-date" class="input !w-auto" type="date" value={dateStr} />
      <button id="print-day" type="button" class="btn-ghost !text-xs">Imprimir</button>
      <a href="/app/waitlist" class="btn-ghost !text-xs">Espera ({stats.waitlistCount})</a>
      <button id="new-apt-btn" type="button" class="btn-primary">+ Nueva cita</button>
    </div>
  </div>

  <div class="mb-4 flex gap-2 overflow-x-auto pb-1">
    {week.map((d) => (
      <a
        href={`/app?date=${d.date}`}
        class:list={[
          'chip shrink-0 border',
          d.date === dateStr ? 'border-gold bg-gold-dim text-gold' : 'border-border text-ink-soft',
        ]}
      >
        {d.date.slice(5)} · {d.count}
      </a>
    ))}
  </div>

  <div class="mb-6 grid gap-3 sm:grid-cols-3 lg:grid-cols-6">
    <div class="card p-4">
      <p class="text-xs font-bold uppercase tracking-wider text-muted">Hoy</p>
      <p class="mt-1 brand-mark text-3xl text-gold">{stats.todayCount}</p>
    </div>
    <div class="card p-4">
      <p class="text-xs font-bold uppercase tracking-wider text-muted">Pendientes</p>
      <p class="mt-1 brand-mark text-3xl font-bold">{stats.pendingCount}</p>
    </div>
    <div class="card p-4">
      <p class="text-xs font-bold uppercase tracking-wider text-muted">Clientes</p>
      <p class="mt-1 brand-mark text-3xl font-bold">{stats.clientsCount}</p>
    </div>
    <div class="card p-4">
      <p class="text-xs font-bold uppercase tracking-wider text-muted">Servicios</p>
      <p class="mt-1 brand-mark text-3xl">{stats.servicesCount}</p>
    </div>
    <div class="card p-4">
      <p class="text-xs font-bold uppercase tracking-wider text-muted">Semana RD$</p>
      <p class="mt-1 brand-mark text-2xl text-gold">{stats.weekRevenue}</p>
    </div>
    <div class="card p-4">
      <p class="text-xs font-bold uppercase tracking-wider text-muted">No-show</p>
      <p class="mt-1 brand-mark text-3xl">{stats.noShowCount}</p>
    </div>
  </div>

  <div id="print-area" class="card overflow-hidden">
    <div class="bay" id="bay" data-open={openHour} data-close={closeHour} data-date={dateStr}>
      <div class="bay__hours">
        {hours.map((h) => (
          <div class="bay__hour">{String(h).padStart(2, '0')}:00</div>
        ))}
      </div>
      <div class="bay__track" id="bay-track" style={`height:${hours.length * 64}px`}>
        {board.appointments.map((a) => {
          const start = new Date(a.startAt);
          const end = new Date(a.endAt);
          const startMin = start.getHours() * 60 + start.getMinutes();
          const endMin = end.getHours() * 60 + end.getMinutes();
          const openMin = openHour * 60;
          const top = ((startMin - openMin) / 60) * 64;
          const height = Math.max(((endMin - startMin) / 60) * 64, 36);
          const time = `${String(start.getHours()).padStart(2, '0')}:${String(start.getMinutes()).padStart(2, '0')}`;
          return (
            <button
              type="button"
              class:list={['bay__slot', a.status === 'cancelled' && 'is-cancelled']}
              style={`top:${top}px;height:${height}px;background:${a.colorHex}`}
              data-id={a.id}
              data-status={a.status}
            >
              <div class="bay__slot-title">{a.client?.name || 'Cliente'}</div>
              <div class="bay__slot-meta">
                {time} · {a.service?.name || 'Servicio'}
                {a.haircutStyle ? ` · ${cutStyleLabel(a.haircutStyle)}` : ''}
                {a.code ? ` · ${a.code}` : ''}
              </div>
            </button>
          );
        })}
      </div>
    </div>
  </div>

  <!-- Modal nueva cita -->
  <dialog id="apt-modal" class="w-[min(100%,440px)] rounded-xl border border-border bg-surface p-0 shadow-xl backdrop:bg-black/60">
    <form id="apt-form" class="p-5 sm:p-6">
      <h2 class="brand-mark text-2xl font-bold">Nueva cita</h2>
      <div class="mt-4 space-y-3">
        <div>
          <label class="label" for="clientName">Cliente</label>
          <input class="input" id="clientName" name="clientName" list="clients-list" required />
          <datalist id="clients-list">
            {board.clients.map((c) => <option value={c.name} data-id={c.id} data-email={c.email} data-phone={c.phone} />)}
          </datalist>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="label" for="clientPhone">Teléfono</label>
            <input class="input" id="clientPhone" name="clientPhone" />
          </div>
          <div>
            <label class="label" for="clientEmail">Email</label>
            <input class="input" id="clientEmail" name="clientEmail" type="email" />
          </div>
        </div>
        <div>
          <label class="label" for="serviceId">Servicio</label>
          <select class="input" id="serviceId" name="serviceId" required>
            {board.services.map((s) => (
              <option value={s.id} data-color={s.color} data-duration={s.durationMin}>
                {s.name} · {s.durationMin} min · ${s.price}
              </option>
            ))}
          </select>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="label" for="aptDate">Fecha</label>
            <input class="input" id="aptDate" name="aptDate" type="date" value={dateStr} required />
          </div>
          <div>
            <label class="label" for="aptTime">Hora</label>
            <input class="input" id="aptTime" name="aptTime" type="time" value="10:00" required />
          </div>
        </div>
        <div>
          <label class="label" for="color">Color</label>
          <select class="input" id="color" name="color">
            {board.colors.map((c) => <option value={c.id}>{c.label}</option>)}
          </select>
        </div>
        <div>
          <label class="label" for="notes">Notas</label>
          <textarea class="input" id="notes" name="notes" rows="2"></textarea>
        </div>
        <p id="apt-error" class="hidden text-sm font-medium text-red-600"></p>
      </div>
      <div class="mt-5 flex justify-end gap-2">
        <button type="button" class="btn-ghost" id="apt-cancel">Cancelar</button>
        <button type="submit" class="btn-primary">Guardar cita</button>
      </div>
    </form>
  </dialog>

  <script>
    const bayDate = document.getElementById('bay-date') as HTMLInputElement;
    const modal = document.getElementById('apt-modal') as HTMLDialogElement;
    const form = document.getElementById('apt-form') as HTMLFormElement;
    const errorEl = document.getElementById('apt-error')!;
    const serviceSelect = document.getElementById('serviceId') as HTMLSelectElement;
    const colorSelect = document.getElementById('color') as HTMLSelectElement;

    bayDate?.addEventListener('change', () => {
      location.href = `/app?date=${bayDate.value}`;
    });

    document.getElementById('new-apt-btn')?.addEventListener('click', () => {
      const opt = serviceSelect.selectedOptions[0];
      if (opt?.dataset.color) colorSelect.value = opt.dataset.color;
      modal.showModal();
    });

    document.getElementById('apt-cancel')?.addEventListener('click', () => modal.close());

    serviceSelect?.addEventListener('change', () => {
      const opt = serviceSelect.selectedOptions[0];
      if (opt?.dataset.color) colorSelect.value = opt.dataset.color;
    });

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorEl.classList.add('hidden');
      const fd = new FormData(form);
      const date = String(fd.get('aptDate'));
      const time = String(fd.get('aptTime'));
      const startAt = new Date(`${date}T${time}:00`).toISOString();

      const res = await fetch('/api/appointments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          clientName: fd.get('clientName'),
          clientPhone: fd.get('clientPhone'),
          clientEmail: fd.get('clientEmail'),
          serviceId: fd.get('serviceId'),
          startAt,
          color: fd.get('color'),
          notes: fd.get('notes'),
          notify: true,
        }),
      });
      const json = await res.json();
      if (!res.ok) {
        errorEl.textContent = json.error || 'Error';
        errorEl.classList.remove('hidden');
        return;
      }
      location.reload();
    });

    document.querySelectorAll('.bay__slot').forEach((el) => {
      el.addEventListener('click', async () => {
        const id = (el as HTMLElement).dataset.id;
        const status = (el as HTMLElement).dataset.status;
        if (!id || status === 'cancelled') return;

        const action = prompt(
          'Acción: 1=Completada 2=Cancelar 3=No-show 4=Reagendar (hora HH:MM)',
          '1',
        );
        if (!action) return;

        if (action === '1') {
          await fetch(`/api/appointments/${id}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status: 'completed' }),
          });
        } else if (action === '2') {
          const reason = prompt('Motivo de cancelación (opcional)') || '';
          await fetch(`/api/appointments/${id}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status: 'cancelled', cancelReason: reason, notify: true }),
          });
        } else if (action === '3') {
          await fetch(`/api/appointments/${id}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status: 'no_show' }),
          });
        } else if (action === '4') {
          const time = prompt('Nueva hora (HH:MM)', '10:00');
          if (!time) return;
          const date = (document.getElementById('bay-date') as HTMLInputElement).value;
          const startAt = new Date(`${date}T${time}:00`).toISOString();
          await fetch(`/api/appointments/${id}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ startAt, notify: true }),
          });
        }
        location.reload();
      });
    });

    document.getElementById('print-day')?.addEventListener('click', () => window.print());
  </script>
</AppLayout>
