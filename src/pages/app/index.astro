---
import AppLayout from '../../layouts/AppLayout.astro';
import { statusLabel } from '../../lib/appointment-status';
import { buildDayBoard } from '../../lib/day-board';
import { cutStyleLabel } from '../../lib/cut-styles';
import { adminServiceMeta } from '../../lib/service-display';
import { getBoardDay, getBoardWeek, getDashboardStats } from '../../lib/store';

const tenantId = Astro.locals.tenantId!;
const tenant = Astro.locals.tenant!;

const today = new Date();
const todayStr = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, '0')}-${String(today.getDate()).padStart(2, '0')}`;
const qDate = Astro.url.searchParams.get('date') || '';
const dateStr = /^\d{4}-\d{2}-\d{2}$/.test(qDate) ? qDate : todayStr;

const [board, stats, week] = await Promise.all([
  getBoardDay(tenantId, dateStr),
  getDashboardStats(tenantId),
  getBoardWeek(tenantId, todayStr),
]);

const daySlots = buildDayBoard(tenant, dateStr, board.appointments);
const currency = board.tenant?.currency === 'DOP' ? 'RD$' : board.tenant?.currency || 'RD$';
const defaultServiceId = board.services[0]?.id || '';

function formatWhen(iso: string) {
  return new Intl.DateTimeFormat('es', {
    weekday: 'short',
    day: 'numeric',
    month: 'short',
    hour: '2-digit',
    minute: '2-digit',
  }).format(new Date(iso));
}

function aptDay(iso: string) {
  const d = new Date(iso);
  return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
}
---

<AppLayout title="Centro de comandos" active="bahia">
  <div class="mb-5 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-[11px] font-bold uppercase tracking-[0.16em] text-navy">Centro de comandos</p>
      <h1 class="font-display mt-1 text-2xl font-bold tracking-tight text-ink sm:text-3xl">Bahía del día</h1>
      <p class="mt-1 text-sm text-muted">Todos los horarios visibles · acciones directas en cada cita</p>
    </div>
    <div class="flex flex-wrap items-center gap-2">
      <input id="bay-date" class="input !w-auto !rounded-lg" type="date" value={dateStr} />
      <button id="print-day" type="button" class="btn-ghost btn-sm">Imprimir</button>
      <a href="/app/waitlist" class="btn-ghost btn-sm">Espera ({stats.waitlistCount})</a>
      <button id="new-apt-btn" type="button" class="btn-primary btn-sm">+ Nueva cita</button>
    </div>
  </div>

  <div class="mb-4 flex gap-1.5 overflow-x-auto pb-1">
    {week.map((d) => (
      <a
        href={`/app?date=${d.date}`}
        class:list={[
          'chip shrink-0 border rounded-md',
          d.date === dateStr ? 'border-navy bg-violet-dim text-navy font-bold' : 'border-border text-muted bg-surface',
        ]}
      >
        {d.date?.slice(5) ?? '—'} · {d.count}
      </a>
    ))}
  </div>

  <div class="mb-5 grid gap-2 grid-cols-3 lg:grid-cols-6">
    <div class="stat-card">
      <p class="text-[10px] font-bold uppercase tracking-wider text-muted">Hoy</p>
      <p class="stat-card__value mt-1">{stats.todayCount}</p>
    </div>
    <div class="stat-card">
      <p class="text-[10px] font-bold uppercase tracking-wider text-muted">Pendientes</p>
      <p class="stat-card__value stat-card__value--warn mt-1">{stats.pendingCount}</p>
    </div>
    <div class="stat-card">
      <p class="text-[10px] font-bold uppercase tracking-wider text-muted">Clientes</p>
      <p class="stat-card__value mt-1">{stats.clientsCount}</p>
    </div>
    <div class="stat-card">
      <p class="text-[10px] font-bold uppercase tracking-wider text-muted">Servicios</p>
      <p class="stat-card__value mt-1">{stats.servicesCount}</p>
    </div>
    <div class="stat-card">
      <p class="text-[10px] font-bold uppercase tracking-wider text-muted">Semana</p>
      <p class="stat-card__value stat-card__value--accent mt-1 text-xl">{currency}{stats.weekRevenue.toLocaleString('es-DO')}</p>
    </div>
    <div class="stat-card">
      <p class="text-[10px] font-bold uppercase tracking-wider text-muted">No-show</p>
      <p class="stat-card__value mt-1">{stats.noShowCount}</p>
    </div>
  </div>

  {stats.pendingList?.length > 0 && (
    <div class="card mb-4 border-2 border-gold/40 bg-gold-dim p-4">
      <div class="mb-3 flex flex-wrap items-center justify-between gap-2">
        <h2 class="font-display text-lg font-bold text-ink">
          Pendientes de confirmar ({stats.pendingCount})
        </h2>
        <p class="text-xs text-muted">Confirma o rechaza antes de atender</p>
      </div>
      <div class="space-y-2">
        {stats.pendingList.map((a) => (
          <div class="flex flex-wrap items-center justify-between gap-3 rounded-lg border border-gold/30 bg-surface p-3">
            <div>
              <p class="text-sm font-semibold text-ink">{a.client?.name || 'Cliente'}</p>
              <p class="text-xs text-muted">
                {a.service?.name} · {formatWhen(a.startAt)}
                {a.code ? ` · ${a.code}` : ''}
              </p>
            </div>
            <div class="flex flex-wrap gap-2">
              <a href={`/app?date=${aptDay(a.startAt)}`} class="btn-ghost btn-sm">Ver en bahía</a>
              <button type="button" class="btn-action btn-action--confirm cmd-act" data-id={a.id} data-action="confirmed" data-notify="1">Confirmar</button>
              <button type="button" class="btn-action btn-action--danger cmd-act" data-id={a.id} data-action="cancelled" data-notify="1">Rechazar</button>
            </div>
          </div>
        ))}
      </div>
    </div>
  )}

  <div id="print-area" class="card p-4 sm:p-5">
    <div class="cmd-board__header">
      <span>Hora</span>
      <span>Estado / acciones</span>
    </div>
    <div class="cmd-board mt-2">
      {daySlots.length === 0 && (
        <p class="py-8 text-center text-sm text-muted">Día cerrado o sin horario configurado.</p>
      )}
      {daySlots.map((slot) => (
        <div class="cmd-row" style={slot.span > 1 ? `min-height:${slot.span * 4.5}rem` : undefined}>
          <div class="cmd-row__time">{slot.time}</div>

          {slot.kind === 'free' && (
            <button
              type="button"
              class="cmd-slot cmd-slot--free cmd-free-slot"
              data-time={slot.time}
              data-start={slot.startAt}
            >
              <span class="cmd-slot__label">+ Disponible — reservar</span>
              <span class="text-[11px] text-muted">Clic para agendar</span>
            </button>
          )}

          {slot.kind === 'past' && (
            <div class="cmd-slot cmd-slot--past">
              <span class="text-xs text-muted">Horario pasado</span>
            </div>
          )}

          {slot.kind === 'lunch' && (
            <div class="cmd-slot cmd-slot--lunch">
              <span>Almuerzo</span>
            </div>
          )}

          {slot.kind === 'booked' && slot.appointment && (
            <div
              class:list={[
                'cmd-slot cmd-slot--booked',
                `is-${slot.appointment.status}`,
              ]}
              style={slot.span > 1 ? `min-height:${slot.span * 4.25 - 0.25}rem` : undefined}
              data-id={slot.appointment.id}
            >
              <div class="cmd-slot__top">
                <div>
                  <p class="cmd-slot__client">{slot.appointment.client?.name || 'Cliente'}</p>
                  <p class="cmd-slot__meta">
                    {slot.appointment.service?.name}
                    {slot.appointment.haircutStyle ? ` · ${cutStyleLabel(slot.appointment.haircutStyle)}` : ''}
                    {slot.appointment.service?.pricingMode !== 'quote' ? ` · ${currency}${slot.appointment.service?.price || 0}` : ' · Precio variable'}
                    {slot.appointment.code ? ` · ${slot.appointment.code}` : ''}
                  </p>
                </div>
                <span class={`status-badge status-badge--${slot.appointment.status}`}>
                  {statusLabel(slot.appointment.status)}
                </span>
              </div>
              <div class="cmd-slot__actions">
                {slot.appointment.status === 'pending' && (
                  <>
                    <button type="button" class="btn-action btn-action--confirm cmd-act" data-id={slot.appointment.id} data-action="confirmed" data-notify="1">Confirmar</button>
                    <button type="button" class="btn-action btn-action--danger cmd-act" data-id={slot.appointment.id} data-action="cancelled" data-notify="1">Rechazar</button>
                  </>
                )}
                {slot.appointment.status === 'confirmed' && (
                  <>
                    <button type="button" class="btn-action btn-action--confirm cmd-act" data-id={slot.appointment.id} data-action="received">Recibir</button>
                    <button type="button" class="btn-action btn-action--confirm cmd-act" data-id={slot.appointment.id} data-action="completed">Hecho</button>
                    <button type="button" class="btn-action cmd-act-reschedule" data-id={slot.appointment.id} data-time={slot.time}>Cambiar hora</button>
                    <button type="button" class="btn-action btn-action--danger cmd-act" data-id={slot.appointment.id} data-action="cancelled" data-notify="1">Quitar</button>
                  </>
                )}
                {slot.appointment.status === 'received' && (
                  <>
                    <button type="button" class="btn-action btn-action--confirm cmd-act" data-id={slot.appointment.id} data-action="completed">Hecho</button>
                    <button type="button" class="btn-action cmd-act-reschedule" data-id={slot.appointment.id} data-time={slot.time}>Cambiar hora</button>
                  </>
                )}
                {slot.appointment.status === 'completed' && (
                  <button type="button" class="btn-action btn-action--confirm cmd-act" data-id={slot.appointment.id} data-action="invoiced">Facturar</button>
                )}
                {(slot.appointment.status === 'confirmed' || slot.appointment.status === 'received') && (
                  <button type="button" class="btn-action cmd-act" data-id={slot.appointment.id} data-action="no_show">No-show</button>
                )}
              </div>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>

  <dialog id="apt-modal" class="apt-dialog">
    <form id="apt-form" class="p-5 sm:p-6">
      <h2 class="font-display text-xl font-semibold text-ink">Nueva cita</h2>
      <div class="mt-4 space-y-3">
        <div>
          <label class="label" for="clientName">Cliente</label>
          <input class="input" id="clientName" name="clientName" list="clients-list" required />
          <datalist id="clients-list">
            {board.clients.map((c) => <option value={c.name} />)}
          </datalist>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="label" for="clientPhone">Teléfono</label>
            <input class="input" id="clientPhone" name="clientPhone" />
          </div>
          <div>
            <label class="label" for="clientEmail">Email</label>
            <input class="input" id="clientEmail" name="clientEmail" type="email" />
          </div>
        </div>
        <div>
          <label class="label" for="serviceId">Servicio</label>
          <select class="input" id="serviceId" name="serviceId" required>
            {board.services.map((s) => (
              <option value={s.id} selected={s.id === defaultServiceId}>
                {s.name} · {adminServiceMeta(s, board.tenant?.currency || 'DOP')}
              </option>
            ))}
          </select>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="label" for="aptDate">Fecha</label>
            <input class="input" id="aptDate" name="aptDate" type="date" value={dateStr} required />
          </div>
          <div>
            <label class="label" for="aptTime">Hora</label>
            <input class="input" id="aptTime" name="aptTime" type="time" value="10:00" required />
          </div>
        </div>
        <div>
          <label class="label" for="notes">Notas</label>
          <textarea class="input" id="notes" name="notes" rows="2"></textarea>
        </div>
        <p id="apt-error" class="hidden text-sm font-medium text-red-600"></p>
      </div>
      <div class="mt-5 flex justify-end gap-2">
        <button type="button" class="btn-ghost" id="apt-cancel">Cancelar</button>
        <button type="submit" class="btn-primary">Guardar</button>
      </div>
    </form>
  </dialog>

  <script>
    import { confirmAction, promptText, toast } from '../../scripts/ui-feedback.js';

    const bayDate = document.getElementById('bay-date');
    const modal = document.getElementById('apt-modal');
    const form = document.getElementById('apt-form');
    const errorEl = document.getElementById('apt-error');
    const aptTime = document.getElementById('aptTime');
    const dateStr = document.getElementById('bay-date')?.value || '';

    bayDate?.addEventListener('change', () => {
      location.href = `/app?date=${bayDate.value}`;
    });

    function openModal(time) {
      if (aptTime && time) aptTime.value = time;
      modal?.showModal();
    }

    document.getElementById('new-apt-btn')?.addEventListener('click', () => openModal('10:00'));
    document.getElementById('apt-cancel')?.addEventListener('click', () => modal?.close());

    (function prefillFromUrl() {
      const p = new URLSearchParams(location.search);
      if (p.get('newApt') !== '1') return;
      const set = (id, val) => {
        const el = document.getElementById(id);
        if (el && val) (el as HTMLInputElement).value = val;
      };
      set('clientName', p.get('clientName') || '');
      set('clientPhone', p.get('clientPhone') || '');
      set('clientEmail', p.get('clientEmail') || '');
      set('aptDate', p.get('date') || dateStr);
      const svc = document.getElementById('serviceId') as HTMLSelectElement | null;
      if (svc && p.get('serviceId')) svc.value = p.get('serviceId')!;
      openModal('10:00');
    })();

    document.querySelectorAll('.cmd-free-slot').forEach((btn) => {
      btn.addEventListener('click', () => {
        const aptDateEl = document.getElementById('aptDate') as HTMLInputElement | null;
        if (aptDateEl && bayDate?.value) aptDateEl.value = bayDate.value;
        openModal(btn.dataset.time || '10:00');
      });
    });

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorEl?.classList.add('hidden');
      const fd = new FormData(form);
      const aptDate = String(fd.get('aptDate'));
      const aptTime = String(fd.get('aptTime'));

      const res = await fetch('/api/appointments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          clientName: fd.get('clientName'),
          clientPhone: fd.get('clientPhone'),
          clientEmail: fd.get('clientEmail'),
          serviceId: fd.get('serviceId'),
          aptDate,
          aptTime,
          notes: fd.get('notes'),
          notify: true,
        }),
      });
      const json = await res.json();
      if (!res.ok) {
        if (errorEl) errorEl.textContent = json.error || 'Error';
        errorEl?.classList.remove('hidden');
        return;
      }
      location.reload();
    });

    async function patchAppointment(id, body) {
      const res = await fetch(`/api/appointments/${id}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      if (!res.ok) {
        const json = await res.json();
        toast(json.error || 'No se pudo actualizar', 'error');
        return false;
      }
      location.reload();
      return true;
    }

    document.querySelectorAll('.cmd-act').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.id;
        const action = btn.dataset.action;
        if (!id || !action) return;
        const payload = { status: action };
        if (btn.dataset.notify === '1') payload.notify = true;
        if (action === 'cancelled') {
          const ok = await confirmAction('¿Cancelar esta cita?', {
            confirmLabel: 'Sí, cancelar',
            cancelLabel: 'No',
          });
          if (!ok) return;
        }
        await patchAppointment(id, payload);
      });
    });

    document.querySelectorAll('.cmd-act-reschedule').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.id;
        const time = await promptText('Nueva hora (HH:MM)', btn.dataset.time || '10:00');
        if (!time || !id) return;
        const date = bayDate?.value || dateStr;
        await patchAppointment(id, { aptDate: date, aptTime: time, notify: true });
      });
    });

    document.getElementById('print-day')?.addEventListener('click', () => window.print());
  </script>
</AppLayout>
