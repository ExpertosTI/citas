---
import AppLayout from '../../layouts/AppLayout.astro';
import { baySlotClass, statusLabel } from '../../lib/appointment-status';
import { tenantIdFromRequest } from '../../lib/auth';
import { getBoardDay, getBoardWeek, getDashboardStats } from '../../lib/store';
import { cutStyleLabel } from '../../lib/cut-styles';

const tenantId = tenantIdFromRequest(Astro.request)!;
const today = new Date();
const todayStr = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, '0')}-${String(today.getDate()).padStart(2, '0')}`;
const qDate = Astro.url.searchParams.get('date') || '';
const dateStr = /^\d{4}-\d{2}-\d{2}$/.test(qDate) ? qDate : todayStr;
const [board, stats, week] = await Promise.all([
  getBoardDay(tenantId, dateStr),
  getDashboardStats(tenantId),
  getBoardWeek(tenantId, todayStr),
]);
const openHour = board.tenant?.openHour ?? 9;
const closeHour = board.tenant?.closeHour ?? 19;
const hours = Array.from({ length: closeHour - openHour }, (_, i) => openHour + i);
const currency = board.tenant?.currency === 'DOP' ? 'RD$' : board.tenant?.currency || 'RD$';
---

<AppLayout title="Bahía de citas" active="bahia">
  <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-mustard-deep">Panel del día</p>
      <h1 class="font-display mt-1 text-3xl font-semibold tracking-tight text-ink sm:text-4xl">Bahía de citas</h1>
      <p class="mt-1 text-sm text-muted">Gestiona reservas, recepción y facturación</p>
    </div>
    <div class="flex flex-wrap items-center gap-2">
      <input id="bay-date" class="input !w-auto" type="date" value={dateStr} />
      <button id="print-day" type="button" class="btn-ghost !text-xs">Imprimir</button>
      <a href="/app/waitlist" class="btn-ghost !text-xs">Espera ({stats.waitlistCount})</a>
      <button id="new-apt-btn" type="button" class="btn-primary">+ Nueva cita</button>
    </div>
  </div>

  <div class="mb-4 flex gap-2 overflow-x-auto pb-1">
    {week.map((d) => (
      <a
        href={`/app?date=${d.date}`}
        class:list={[
          'chip shrink-0 border',
          d.date === dateStr ? 'border-mustard bg-gold-dim text-mustard-deep' : 'border-border text-muted',
        ]}
      >
        {d.date.slice(5)} · {d.count}
      </a>
    ))}
  </div>

  <div class="mb-6 grid gap-3 sm:grid-cols-3 lg:grid-cols-6">
    <div class="card p-4">
      <p class="text-[10px] font-bold uppercase tracking-[0.14em] text-muted">Hoy</p>
      <p class="mt-1 font-display text-3xl font-semibold text-ink">{stats.todayCount}</p>
    </div>
    <div class="card p-4">
      <p class="text-[10px] font-bold uppercase tracking-[0.14em] text-muted">Pendientes</p>
      <p class="mt-1 font-display text-3xl font-semibold text-mustard-deep">{stats.pendingCount}</p>
    </div>
    <div class="card p-4">
      <p class="text-[10px] font-bold uppercase tracking-[0.14em] text-muted">Clientes</p>
      <p class="mt-1 font-display text-3xl font-semibold text-ink">{stats.clientsCount}</p>
    </div>
    <div class="card p-4">
      <p class="text-[10px] font-bold uppercase tracking-[0.14em] text-muted">Servicios</p>
      <p class="mt-1 font-display text-3xl font-semibold text-ink">{stats.servicesCount}</p>
    </div>
    <div class="card p-4">
      <p class="text-[10px] font-bold uppercase tracking-[0.14em] text-muted">Semana {currency}</p>
      <p class="mt-1 font-display text-2xl font-semibold text-mustard-deep">{currency}{stats.weekRevenue.toLocaleString('es-DO')}</p>
    </div>
    <div class="card p-4">
      <p class="text-[10px] font-bold uppercase tracking-[0.14em] text-muted">No-show</p>
      <p class="mt-1 font-display text-3xl font-semibold text-ink">{stats.noShowCount}</p>
    </div>
  </div>

  {stats.upcoming.length > 0 && (
    <div class="card mb-6 p-4">
      <p class="text-[10px] font-bold uppercase tracking-[0.14em] text-muted">Próximas citas</p>
      <div class="mt-3 space-y-2">
        {stats.upcoming.map((a) => (
          <div class="flex flex-wrap items-center justify-between gap-2 rounded-xl border border-border bg-white/60 px-3 py-2 text-sm">
            <div>
              <span class="font-semibold text-ink">{a.client?.name || 'Cliente'}</span>
              <span class="text-muted"> · {a.service?.name}</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-xs text-muted">{new Date(a.startAt).toLocaleString('es-DO', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' })}</span>
              <span class:list={['status-badge', `status-badge--${a.status}`]}>{statusLabel(a.status)}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  )}

  <div id="print-area" class="card overflow-hidden">
    <div class="bay" id="bay" data-open={openHour} data-close={closeHour} data-date={dateStr}>
      <div class="bay__hours">
        {hours.map((h) => (
          <div class="bay__hour">{String(h).padStart(2, '0')}:00</div>
        ))}
      </div>
      <div class="bay__track" id="bay-track" style={`height:${hours.length * 64}px`}>
        {board.appointments.map((a) => {
          const start = new Date(a.startAt);
          const end = new Date(a.endAt);
          const startMin = start.getHours() * 60 + start.getMinutes();
          const endMin = end.getHours() * 60 + end.getMinutes();
          const openMin = openHour * 60;
          const top = ((startMin - openMin) / 60) * 64;
          const height = Math.max(((endMin - startMin) / 60) * 64, 36);
          const time = `${String(start.getHours()).padStart(2, '0')}:${String(start.getMinutes()).padStart(2, '0')}`;
          return (
            <button
              type="button"
              class={baySlotClass(a.status)}
              style={`top:${top}px;height:${height}px;background:${a.colorHex}`}
              data-id={a.id}
              data-status={a.status}
              data-client={a.client?.name || 'Cliente'}
              data-phone={a.client?.phone || ''}
              data-email={a.client?.email || ''}
              data-service={a.service?.name || 'Servicio'}
              data-price={a.service?.price || 0}
              data-time={time}
              data-code={a.code || ''}
              data-style={a.haircutStyle ? cutStyleLabel(a.haircutStyle) : ''}
              data-notes={a.notes || ''}
            >
              <div class="bay__slot-title">{a.client?.name || 'Cliente'}</div>
              <div class="bay__slot-meta">
                {time} · {a.service?.name || 'Servicio'}
                {a.haircutStyle ? ` · ${cutStyleLabel(a.haircutStyle)}` : ''}
                {a.status === 'pending' ? ' · Pendiente' : ''}
                {a.status === 'invoiced' ? ' · Facturada' : ''}
              </div>
            </button>
          );
        })}
      </div>
    </div>
  </div>

  <dialog id="apt-modal" class="apt-dialog">
    <form id="apt-form" class="p-5 sm:p-6">
      <h2 class="font-display text-xl font-semibold text-ink">Nueva cita</h2>
      <div class="mt-4 space-y-3">
        <div>
          <label class="label" for="clientName">Cliente</label>
          <input class="input" id="clientName" name="clientName" list="clients-list" required />
          <datalist id="clients-list">
            {board.clients.map((c) => <option value={c.name} data-id={c.id} data-email={c.email} data-phone={c.phone} />)}
          </datalist>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="label" for="clientPhone">Teléfono</label>
            <input class="input" id="clientPhone" name="clientPhone" />
          </div>
          <div>
            <label class="label" for="clientEmail">Email</label>
            <input class="input" id="clientEmail" name="clientEmail" type="email" />
          </div>
        </div>
        <div>
          <label class="label" for="serviceId">Servicio</label>
          <select class="input" id="serviceId" name="serviceId" required>
            {board.services.map((s) => (
              <option value={s.id} data-color={s.color} data-duration={s.durationMin}>
                {s.name} · {s.durationMin} min · ${s.price}
              </option>
            ))}
          </select>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="label" for="aptDate">Fecha</label>
            <input class="input" id="aptDate" name="aptDate" type="date" value={dateStr} required />
          </div>
          <div>
            <label class="label" for="aptTime">Hora</label>
            <input class="input" id="aptTime" name="aptTime" type="time" value="10:00" required />
          </div>
        </div>
        <div>
          <label class="label" for="color">Color</label>
          <select class="input" id="color" name="color">
            {board.colors.map((c) => <option value={c.id}>{c.label}</option>)}
          </select>
        </div>
        <div>
          <label class="label" for="notes">Notas</label>
          <textarea class="input" id="notes" name="notes" rows="2"></textarea>
        </div>
        <p id="apt-error" class="hidden text-sm font-medium text-red-600"></p>
      </div>
      <div class="mt-5 flex justify-end gap-2">
        <button type="button" class="btn-ghost" id="apt-cancel">Cancelar</button>
        <button type="submit" class="btn-primary">Guardar cita</button>
      </div>
    </form>
  </dialog>

  <dialog id="detail-modal" class="apt-dialog">
    <div class="p-5 sm:p-6">
      <div class="flex items-start justify-between gap-3">
        <div>
          <p class="text-[10px] font-semibold uppercase tracking-[0.16em] text-muted">Detalle de cita</p>
          <h2 id="detail-client" class="font-display mt-1 text-xl font-semibold text-ink"></h2>
          <p id="detail-meta" class="mt-1 text-sm text-muted"></p>
        </div>
        <span id="detail-status" class="status-badge"></span>
      </div>
      <dl class="mt-4 space-y-2 text-sm">
        <div class="flex justify-between gap-4"><dt class="text-muted">Servicio</dt><dd id="detail-service" class="font-medium text-ink"></dd></div>
        <div class="flex justify-between gap-4"><dt class="text-muted">Hora</dt><dd id="detail-time" class="font-medium text-ink"></dd></div>
        <div class="flex justify-between gap-4"><dt class="text-muted">Código</dt><dd id="detail-code" class="font-medium text-ink"></dd></div>
        <div class="flex justify-between gap-4"><dt class="text-muted">Precio</dt><dd id="detail-price" class="font-medium text-ink"></dd></div>
        <div id="detail-style-row" class="hidden flex justify-between gap-4"><dt class="text-muted">Estilo</dt><dd id="detail-style" class="font-medium text-ink"></dd></div>
        <div id="detail-notes-row" class="hidden"><dt class="text-muted">Notas</dt><dd id="detail-notes" class="mt-1 text-ink-soft"></dd></div>
      </dl>
      <div id="detail-actions" class="mt-5 flex flex-wrap gap-2"></div>
      <div class="mt-4 flex justify-end">
        <button type="button" class="btn-ghost" id="detail-close">Cerrar</button>
      </div>
    </div>
  </dialog>

  <script define:vars={{ currency }}>
    const bayDate = document.getElementById('bay-date');
    const modal = document.getElementById('apt-modal');
    const detailModal = document.getElementById('detail-modal');
    const form = document.getElementById('apt-form');
    const errorEl = document.getElementById('apt-error');
    const serviceSelect = document.getElementById('serviceId');
    const colorSelect = document.getElementById('color');

    const STATUS_LABELS = {
      pending: 'Pendiente',
      confirmed: 'Confirmada',
      received: 'Recibida',
      completed: 'Completada',
      invoiced: 'Facturada',
      cancelled: 'Cancelada',
      no_show: 'No-show',
    };

    bayDate?.addEventListener('change', () => {
      location.href = `/app?date=${bayDate.value}`;
    });

    document.getElementById('new-apt-btn')?.addEventListener('click', () => {
      const opt = serviceSelect?.selectedOptions[0];
      if (opt?.dataset.color) colorSelect.value = opt.dataset.color;
      modal?.showModal();
    });

    document.getElementById('apt-cancel')?.addEventListener('click', () => modal?.close());
    document.getElementById('detail-close')?.addEventListener('click', () => detailModal?.close());

    serviceSelect?.addEventListener('change', () => {
      const opt = serviceSelect.selectedOptions[0];
      if (opt?.dataset.color) colorSelect.value = opt.dataset.color;
    });

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorEl?.classList.add('hidden');
      const fd = new FormData(form);
      const date = String(fd.get('aptDate'));
      const time = String(fd.get('aptTime'));
      const startAt = new Date(`${date}T${time}:00`).toISOString();

      const res = await fetch('/api/appointments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          clientName: fd.get('clientName'),
          clientPhone: fd.get('clientPhone'),
          clientEmail: fd.get('clientEmail'),
          serviceId: fd.get('serviceId'),
          startAt,
          color: fd.get('color'),
          notes: fd.get('notes'),
          notify: true,
        }),
      });
      const json = await res.json();
      if (!res.ok) {
        if (errorEl) errorEl.textContent = json.error || 'Error';
        errorEl?.classList.remove('hidden');
        return;
      }
      location.reload();
    });

    async function patchAppointment(id, body) {
      const res = await fetch(`/api/appointments/${id}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      if (!res.ok) {
        const json = await res.json();
        alert(json.error || 'No se pudo actualizar');
        return false;
      }
      location.reload();
      return true;
    }

    function actionBtn(label, status, extra = {}) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = status === 'cancelled' ? 'btn-ghost !text-xs' : 'btn-primary !text-xs';
      btn.textContent = label;
      btn.addEventListener('click', () => patchAppointment(extra.id, { status, ...extra.payload }));
      return btn;
    }

    document.querySelectorAll('.bay__slot').forEach((el) => {
      el.addEventListener('click', () => {
        const ds = el.dataset;
        const status = ds.status || 'confirmed';
        if (status === 'cancelled') return;

        document.getElementById('detail-client').textContent = ds.client || 'Cliente';
        document.getElementById('detail-meta').textContent = [ds.phone, ds.email].filter(Boolean).join(' · ') || '—';
        document.getElementById('detail-service').textContent = ds.service || '—';
        document.getElementById('detail-time').textContent = ds.time || '—';
        document.getElementById('detail-code').textContent = ds.code || '—';
        document.getElementById('detail-price').textContent = `${currency}${Number(ds.price || 0).toLocaleString('es-DO')}`;

        const statusEl = document.getElementById('detail-status');
        if (statusEl) {
          statusEl.textContent = STATUS_LABELS[status] || status;
          statusEl.className = `status-badge status-badge--${status}`;
        }

        const styleRow = document.getElementById('detail-style-row');
        if (ds.style) {
          styleRow?.classList.remove('hidden');
          document.getElementById('detail-style').textContent = ds.style;
        } else {
          styleRow?.classList.add('hidden');
        }

        const notesRow = document.getElementById('detail-notes-row');
        if (ds.notes) {
          notesRow?.classList.remove('hidden');
          document.getElementById('detail-notes').textContent = ds.notes;
        } else {
          notesRow?.classList.add('hidden');
        }

        const actions = document.getElementById('detail-actions');
        if (actions) {
          actions.innerHTML = '';
          const id = ds.id;
          const base = { id };

          if (status === 'pending') {
            actions.appendChild(actionBtn('Aceptar', 'confirmed', { ...base, payload: { notify: true } }));
            actions.appendChild(actionBtn('Rechazar', 'cancelled', { ...base, payload: { notify: true } }));
          }
          if (status === 'confirmed') {
            actions.appendChild(actionBtn('Recibir cliente', 'received', base));
            actions.appendChild(actionBtn('Completada', 'completed', base));
            actions.appendChild(actionBtn('No-show', 'no_show', base));
            actions.appendChild(actionBtn('Cancelar', 'cancelled', { ...base, payload: { notify: true } }));
          }
          if (status === 'received') {
            actions.appendChild(actionBtn('Completada', 'completed', base));
            actions.appendChild(actionBtn('No-show', 'no_show', base));
          }
          if (status === 'completed') {
            actions.appendChild(actionBtn('Marcar facturada', 'invoiced', base));
          }

          const reschedule = document.createElement('button');
          reschedule.type = 'button';
          reschedule.className = 'btn-ghost !text-xs';
          reschedule.textContent = 'Reagendar';
          reschedule.addEventListener('click', async () => {
            const time = prompt('Nueva hora (HH:MM)', ds.time || '10:00');
            if (!time) return;
            const date = bayDate?.value || '';
            const startAt = new Date(`${date}T${time}:00`).toISOString();
            await patchAppointment(id, { startAt, notify: true });
          });
          if (status !== 'invoiced' && status !== 'completed') actions.appendChild(reschedule);
        }

        detailModal?.showModal();
      });
    });

    document.getElementById('print-day')?.addEventListener('click', () => window.print());
  </script>
</AppLayout>
