---
import AppLayout from '../../layouts/AppLayout.astro';
import { getServices, getWaitlist } from '../../lib/store';
import { bookAppUrl, telUrl, whatsAppUrl } from '../../scripts/client-actions.js';

const tenantId = Astro.locals.tenantId!;
const [waitlist, services] = await Promise.all([getWaitlist(tenantId), getServices(tenantId)]);
const businessName = Astro.locals.tenant?.businessName || 'tu negocio';
---

<AppLayout title="Lista de espera" active="bahia">
  <div class="mb-6">
    <h1 class="brand-mark text-3xl">Lista de espera</h1>
    <p class="mt-1 text-sm text-ink-soft">Clientes que buscaron cupo cuando no había horario</p>
  </div>

  <div class="card divide-y divide-border">
    {waitlist.length === 0 && (
      <p class="p-6 text-sm text-muted">Nadie en lista de espera.</p>
    )}
    {waitlist.map((w) => {
      const svc = services.find((s) => s.id === w.serviceId);
      const name = w.clientName?.trim() || 'Cliente sin nombre';
      const phone = w.clientPhone?.trim() || '';
      const email = w.clientEmail?.trim() || '';
      const wa = whatsAppUrl(phone, `Hola ${name}, hay cupo en ${businessName}. ¿Te agendo?`);
      const tel = telUrl(phone);
      const book = bookAppUrl({
        date: w.preferredDate,
        clientName: name,
        clientPhone: phone,
        clientEmail: email,
        serviceId: w.serviceId,
      });
      return (
        <article class="client-card">
          <div class="client-card__main">
            <p class="client-card__name">{name}</p>
            <p class="client-card__meta">
              {w.preferredDate} · {svc?.name || 'Servicio'}
              {phone ? ` · ${phone}` : email ? ` · ${email}` : ''}
            </p>
            {w.notes && <p class="client-card__meta mt-1">{w.notes}</p>}
          </div>
          <div class="client-card__actions">
            {wa && (
              <a class="client-card__btn client-card__btn--wa" href={wa} target="_blank" rel="noopener noreferrer">
                WhatsApp
              </a>
            )}
            {tel && (
              <a class="client-card__btn" href={tel}>Llamar</a>
            )}
            <a class="client-card__btn client-card__btn--primary" href={book}>Agendar cita</a>
            <button type="button" class="client-card__btn client-card__btn--danger del-wl" data-id={w.id}>
              Quitar
            </button>
          </div>
        </article>
      );
    })}
  </div>

  <script>
    import { confirmAction, toast } from '../../scripts/ui-feedback.js';

    document.querySelectorAll('.del-wl').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const ok = await confirmAction('¿Quitar de la lista de espera?', {
          confirmLabel: 'Quitar',
          cancelLabel: 'Cancelar',
        });
        if (!ok) return;
        const id = (btn as HTMLElement).dataset.id;
        const res = await fetch(`/api/waitlist/manage?id=${encodeURIComponent(id || '')}`, { method: 'DELETE' });
        if (!res.ok) {
          toast('No se pudo quitar', 'error');
          return;
        }
        location.reload();
      });
    });
  </script>
</AppLayout>
