---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BookWizard from '../../../components/BookWizard.astro';
import { getServices, getTenantBySlug, publicTenant } from '../../../lib/store';

const slug = Astro.params.slug || '';
const tenant = await getTenantBySlug(slug);

if (!tenant) {
  return Astro.redirect('/?error=salon');
}

const t = publicTenant(tenant);
const services = (await getServices(tenant.id)).filter((s) => s.active);
const logoSrc = t.logoUrl?.startsWith('http') ? t.logoUrl : `/api/logo/${tenant.id}`;
---

<BaseLayout title={`Reservar · ${t.businessName}`} description={t.bio}>
  <div class="app-scene min-h-dvh">
    <div class="relative z-10 mx-auto max-w-xl px-4 pb-16 pt-8">
      <div class="mb-6 text-center">
        <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-mustard-deep">Reserva en línea</p>
        <div class="mt-4 flex flex-col items-center gap-3">
          <img
            src={logoSrc}
            alt={t.businessName}
            class="h-20 w-20 rounded-2xl border border-black/8 object-cover bg-white shadow-sm"
            onerror="this.style.display='none'"
          />
          <h1 class="brand-mark text-3xl sm:text-4xl">{t.businessName}</h1>
        </div>
        <p class="mt-2 text-sm text-muted">{t.bio}</p>
        <p class="mt-2 text-sm text-muted">{[t.city, t.phone].filter(Boolean).join(' · ')}</p>
      </div>

      {services.length === 0 ? (
        <div class="card p-6 text-center text-sm text-muted">Este local aún no tiene servicios activos.</div>
      ) : (
        <BookWizard
          slug={t.slug}
          services={services}
          currency={t.currency}
          whatsapp={t.whatsapp || t.phone}
          accentColor={t.accentColor}
        />
      )}

      <p class="mt-6 text-center text-xs text-muted">
        <a class="font-semibold text-navy" href="https://citas.renace.tech">Citas · renace.tech</a>
      </p>
    </div>
  </div>
</BaseLayout>
