---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BookWizard from '../../../components/BookWizard.astro';
import { getServices, getTenantBySlug, publicTenant } from '../../../lib/store';

const slug = Astro.params.slug || '';
const tenant = await getTenantBySlug(slug);

if (!tenant) {
  return Astro.redirect('/?error=salon');
}

const t = publicTenant(tenant);
const services = (await getServices(tenant.id)).filter((s) => s.active);
const logoSrc = t.logoUrl?.startsWith('http') ? t.logoUrl : `/api/logo/${tenant.id}`;
---

<BaseLayout title={`Reservar · ${t.businessName}`} description={t.bio}>
  <div class="app-scene min-h-dvh">
    <div class="accent-line"></div>
    <header class="mx-auto max-w-lg px-4 py-8 text-center">
      <p class="text-xs font-semibold uppercase tracking-wider text-muted">Reserva en línea</p>
      <div class="mt-4 flex flex-col items-center gap-3">
        <img
          src={logoSrc}
          alt={t.businessName}
          class="h-24 w-24 rounded-lg border-2 border-gold/30 object-cover bg-surface-2 shadow-lg"
          onerror="this.style.display='none'"
        />
        <h1 class="brand-mark brand-mark--gold text-5xl">{t.businessName}</h1>
      </div>
      <p class="mt-2 text-sm text-ink-soft">{t.bio}</p>
      <p class="mt-3 text-sm text-muted">{[t.city, t.phone].filter(Boolean).join(' · ')}</p>
      {t.instagram && (
        <a
          class="mt-2 inline-block text-sm text-gold"
          href={`https://instagram.com/${t.instagram.replace('@', '')}`}
          target="_blank"
          rel="noreferrer"
        >
          @{t.instagram.replace('@', '')}
        </a>
      )}
    </header>

    <main class="mx-auto max-w-lg px-4 pb-16">
      {services.length === 0 ? (
        <div class="card p-6 text-center text-sm text-muted">Este local aún no tiene servicios activos.</div>
      ) : (
        <BookWizard
          slug={t.slug}
          services={services}
          currency={t.currency}
          whatsapp={t.whatsapp || t.phone}
          accentColor={t.accentColor}
        />
      )}

      <p class="mt-6 text-center text-xs text-muted">
        Powered by <a class="font-semibold text-gold" href="https://citas.renace.tech">Citas · renace.tech</a>
      </p>
    </main>
  </div>
</BaseLayout>
