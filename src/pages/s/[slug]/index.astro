---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getServices, getTenantBySlug, publicTenant } from '../../../lib/store';

const slug = Astro.params.slug || '';
const tenant = await getTenantBySlug(slug);

if (!tenant) {
  return Astro.redirect('/?error=salon');
}

const t = publicTenant(tenant);
const services = (await getServices(tenant.id)).filter((s) => s.active);
const today = new Date();
const dateStr = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, '0')}-${String(today.getDate()).padStart(2, '0')}`;
---

<BaseLayout title={`Reservar · ${t.businessName}`} description={t.bio}>
  <div class="salon-pattern min-h-dvh">
    <header class="mx-auto max-w-lg px-4 py-8 text-center">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-muted">Reserva en línea</p>
      <h1 class="mt-2 font-display text-4xl font-bold" style={`color:${t.accentColor}`}>{t.businessName}</h1>
      <p class="mt-2 text-sm text-ink-soft">{t.bio}</p>
      {(t.city || t.phone) && (
        <p class="mt-3 text-sm text-muted">
          {t.city}{t.city && t.phone ? ' · ' : ''}{t.phone}
        </p>
      )}
    </header>

    <main class="mx-auto max-w-lg px-4 pb-16">
      <form id="book-form" class="card space-y-4 p-5 sm:p-6">
        <input type="hidden" name="slug" value={t.slug} />

        <div>
          <label class="label" for="serviceId">Servicio</label>
          <select class="input" id="serviceId" name="serviceId" required>
            {services.map((s) => (
              <option value={s.id}>{s.name} · {s.durationMin} min · ${s.price}</option>
            ))}
          </select>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="label" for="date">Fecha</label>
            <input class="input" id="date" name="date" type="date" value={dateStr} min={dateStr} required />
          </div>
          <div>
            <label class="label" for="time">Hora</label>
            <input class="input" id="time" name="time" type="time" value="10:00" required />
          </div>
        </div>

        <div>
          <label class="label" for="name">Tu nombre</label>
          <input class="input" id="name" name="name" required />
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="label" for="phone">Teléfono</label>
            <input class="input" id="phone" name="phone" />
          </div>
          <div>
            <label class="label" for="email">Email</label>
            <input class="input" id="email" name="email" type="email" />
          </div>
        </div>

        <div>
          <label class="label" for="notes">Notas</label>
          <textarea class="input" id="notes" name="notes" rows="2" placeholder="Preferencias, alergias..."></textarea>
        </div>

        <p id="book-error" class="hidden text-sm font-medium text-red-600"></p>
        <p id="book-ok" class="hidden text-sm font-medium text-emerald-700"></p>

        <button type="submit" class="btn-primary w-full !py-3" style={`background:linear-gradient(135deg,${t.accentColor},${t.accentColor})`}>
          Confirmar cita
        </button>
      </form>

      <p class="mt-6 text-center text-xs text-muted">
        Powered by <a class="font-semibold text-rose-deep" href="https://citas.renace.tech">Citas · renace.tech</a>
      </p>
    </main>
  </div>

  <script>
    const form = document.getElementById('book-form') as HTMLFormElement;
    const errorEl = document.getElementById('book-error')!;
    const okEl = document.getElementById('book-ok')!;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorEl.classList.add('hidden');
      okEl.classList.add('hidden');
      const fd = new FormData(form);
      const startAt = new Date(`${fd.get('date')}T${fd.get('time')}:00`).toISOString();

      const res = await fetch('/api/book', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          slug: fd.get('slug'),
          serviceId: fd.get('serviceId'),
          startAt,
          name: fd.get('name'),
          phone: fd.get('phone'),
          email: fd.get('email'),
          notes: fd.get('notes'),
        }),
      });
      const json = await res.json();
      if (!res.ok) {
        errorEl.textContent = json.error || 'No se pudo reservar';
        errorEl.classList.remove('hidden');
        return;
      }
      okEl.textContent = '¡Cita confirmada! Te enviamos un email si dejaste correo.';
      okEl.classList.remove('hidden');
      form.reset();
    });
  </script>
</BaseLayout>
