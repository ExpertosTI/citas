---
import BaseLayout from '../layouts/BaseLayout.astro';
import FeatureDemo from '../components/FeatureDemo.astro';
import LandingIcon from '../components/LandingIcon.astro';
import { geoFromRequest } from '../lib/geo';

const geo = geoFromRequest(Astro.request);

const features = [
  {
    icon: 'ai',
    variant: 'ai' as const,
    t: 'Asistente AI',
    d: 'Describe tu negocio en lenguaje natural. Servicios, fotos, horario y marca — configurado en minutos.',
    size: 'hero',
    highlight: true,
  },
  {
    icon: 'bay',
    variant: 'bay' as const,
    t: 'Bahía de citas',
    d: 'Vista del día con colores. Completa, reagenda o marca no-show al instante.',
    size: 'tall',
  },
  {
    icon: 'book',
    variant: 'book' as const,
    t: 'Reservas en línea',
    d: 'Link propio para que tus clientes agenden solos y elijan servicio y horario.',
    size: 'wide',
  },
  {
    icon: 'notify',
    variant: 'notify' as const,
    t: 'Notificaciones',
    d: 'Confirmaciones y recordatorios por email — automáticos.',
    size: 'compact',
  },
  {
    icon: 'wait',
    variant: 'wait' as const,
    t: 'Lista de espera',
    d: 'Sin cupo, el cliente pide aviso y tú llenas huecos al vuelo.',
    size: 'compact',
  },
  {
    icon: 'brand',
    variant: 'brand' as const,
    t: 'Perfil de marca',
    d: 'Logo, bio, horarios y enlace público — todo desde el panel.',
    size: 'banner',
  },
];
---

<BaseLayout>
  <div class="app-scene relative z-10">
    <header class="reveal mx-auto flex max-w-7xl items-center justify-between px-4 py-5 lg:px-8">
      <a href="/" class="font-display text-xl font-semibold tracking-tight text-ink sm:text-2xl">Citas</a>
      <div class="flex items-center gap-2">
        <span class="geo-badge hidden sm:inline-flex">{geo.city}</span>
        <a href="/login" class="btn-ghost !py-2 !px-4 !text-sm">Entrar</a>
        <a href="/registro" class="btn-primary !py-2 !px-4 !text-sm">Crear mi negocio</a>
      </div>
    </header>

    <section class="mx-auto grid max-w-7xl gap-12 px-4 pb-20 pt-8 lg:grid-cols-2 lg:items-center lg:px-8">
      <div class="reveal">
        <p class="hero-eyebrow text-[11px] font-semibold uppercase tracking-[0.2em] text-mustard-deep">
          Agenda inteligente · {geo.city}
        </p>
        <h1 class="hero-title font-display mt-4 text-4xl font-semibold tracking-tight text-ink sm:text-5xl lg:text-[3.5rem] lg:leading-[1.05]">
          <span data-typewriter="Tu negocio listo en minutos." data-type-speed="38">Tu negocio listo en minutos.</span>
        </h1>
        <p class="hero-copy mt-5 max-w-xl text-base leading-relaxed text-muted sm:text-lg">
          Reservas para barberías, salones y spas. Panel con bahía del día, clientes y enlace público.
        </p>
        <div class="hero-cta mt-8 flex flex-wrap gap-3">
          <a href="/registro" class="btn-primary !px-6 !py-3">Empezar gratis</a>
          <a href="#features" class="btn-ghost !px-6 !py-3">Ver la demo</a>
        </div>
      </div>

      <div class="hero-visual card p-6 sm:p-7" data-parallax="0.08" data-tilt>
        <div class="flex items-center gap-2">
          <LandingIcon name="bay" class="landing-icon--sm" />
          <p class="text-xs font-semibold uppercase tracking-wider text-muted">Panel del día</p>
        </div>
        <p class="brand-mark mt-1 text-2xl">Bahía de citas</p>
        <div class="mt-5 space-y-2.5">
          {[
            { t: '09:00', n: 'Carlos M.', s: 'Corte ejecutivo', c: 'gold' },
            { t: '10:30', n: 'Ana R.', s: 'Color + corte', c: 'crimson' },
            { t: '12:00', n: 'Miguel S.', s: 'Barba premium', c: 'navy' },
          ].map((row, i) => (
            <div class="live-slot reveal" style={`transition-delay: ${0.1 + i * 0.08}s`}>
              <span class:list={['live-slot__dot', `live-slot__dot--${row.c}`]}></span>
              <span class="w-12 shrink-0 text-sm font-bold tabular-nums text-navy">{row.t}</span>
              <div class="min-w-0">
                <p class="truncate font-semibold text-ink">{row.n}</p>
                <p class="truncate text-xs text-muted">{row.s}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="features" class="border-t border-black/5 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="reveal mb-12 max-w-2xl">
          <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-mustard-deep">Producto</p>
          <h2 class="font-display mt-2 text-3xl font-semibold tracking-tight text-ink sm:text-4xl">
            Todo lo que necesitas, en una sola app
          </h2>
          <p class="mt-3 text-base text-muted">
            Cada función con una mini demo — así se ve Citas por dentro.
          </p>
        </div>

        <div class="feature-bento">
          {features.map((f, i) => (
            <article
              class:list={[
                'feature-showcase reveal card',
                `feature-showcase--${f.size}`,
                f.highlight && 'feature-showcase--highlight',
              ]}
              style={`transition-delay: ${(i % 4) * 0.06}s`}
              data-tilt
            >
              <div class="feature-showcase__demo">
                <FeatureDemo variant={f.variant} />
              </div>
              <div class="feature-showcase__body">
                <div class="feature-showcase__head">
                  <LandingIcon name={f.icon} class:list={['landing-icon--feature', f.highlight && 'landing-icon--gold']} />
                  {f.highlight && (
                    <span class="chip border border-gold/30 bg-gold-dim text-mustard-deep">Destacado</span>
                  )}
                </div>
                <h3 class="brand-mark mt-3 text-xl sm:text-2xl">{f.t}</h3>
                <p class="mt-2 text-sm leading-relaxed text-muted sm:text-base">{f.d}</p>
              </div>
            </article>
          ))}
        </div>

        <div class="reveal mt-14 text-center">
          <a href="/registro" class="btn-primary !px-8 !py-3.5 !text-base">Crear mi negocio gratis</a>
          <p class="mt-3 text-sm text-muted">Configuración guiada · Sin tarjeta</p>
        </div>
      </div>
    </section>

    <footer class="reveal border-t border-black/5 py-10 text-center text-sm text-muted">
      <p>Citas · renace.tech</p>
    </footer>
  </div>
</BaseLayout>
