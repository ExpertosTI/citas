---
import BaseLayout from './BaseLayout.astro';
import AssistantPanel from '../components/AssistantPanel.astro';
import { navForTenant } from '../lib/modules/registry';
import { enabledModuleIds, tenantHasModule } from '../lib/modules/tenant-modules';
import { safeTenant } from '../lib/store';

interface Props {
  title?: string;
  active?: 'bahia' | 'servicios' | 'clientes' | 'perfil' | 'asistente' | 'waitlist' | 'pos';
}

const { title = 'Panel', active = 'bahia' } = Astro.props;
const tenantId = Astro.locals.tenantId!;
const tenant = Astro.locals.tenant!;
const t = safeTenant(tenant);
const enabled = enabledModuleIds(tenant);
const nav = navForTenant(enabled);
const showAssistant = tenant.onboardingComplete === true && tenantHasModule(tenant, 'assistant');
const currencyLabel = t.currency === 'DOP' ? 'RD$' : t.currency === 'USD' ? 'USD' : t.currency;
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || 'https://citas.renace.tech').replace(/\/$/, '');
const publicUrl = `${siteUrl}/s/${t.slug}`;
---

<BaseLayout title={`${title} · ${t.businessName}`}>
  <div class="app-scene min-h-dvh">
    <header class="sticky top-0 z-40 border-b border-border bg-surface/95 backdrop-blur-md">
      <div class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 py-3">
        <div class="min-w-0">
          <p class="font-display text-lg font-semibold tracking-tight text-ink sm:text-xl">{t.businessName}</p>
          <a class="truncate text-[11px] text-muted hover:text-mustard-deep" href={publicUrl} target="_blank" rel="noreferrer">
            {publicUrl.replace('https://', '')}
          </a>
        </div>
        <nav class="hidden items-center gap-1 sm:flex">
          {nav.map((item) => (
            <a
              href={item.href}
              class:list={[
                'rounded-full px-3.5 py-2 text-[11px] font-semibold uppercase tracking-[0.14em] transition',
                active === item.id
                  ? 'bg-gold-dim text-mustard-deep'
                  : 'text-muted hover:text-ink',
              ]}
            >
              {item.label}
            </a>
          ))}
          <button id="logout-btn" type="button" class="btn-ghost btn-sm ml-2">Salir</button>
        </nav>
      </div>
      <nav class="flex gap-1 overflow-x-auto border-t border-border px-2 py-2 sm:hidden">
        {nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              'chip whitespace-nowrap',
              active === item.id ? 'bg-gold-dim text-mustard-deep' : 'border border-border text-muted',
            ]}
          >
            {item.icon} {item.label}
          </a>
        ))}
      </nav>
    </header>

    <main class="mx-auto max-w-6xl px-4 py-6">
      <slot />
    </main>

    {showAssistant && (
      <AssistantPanel
        tenantId={tenantId!}
        businessName={t.businessName}
        ownerName={t.ownerName}
        currency={currencyLabel}
      />
    )}
  </div>

  <footer class="app-legal-foot">
    <a href="/privacidad">Privacidad</a>
    <span aria-hidden="true">·</span>
    <a href="/terminos">Términos</a>
    <span aria-hidden="true">·</span>
    <a href="/eliminar-cuenta">Eliminar cuenta</a>
  </footer>

  <script>
    document.getElementById('logout-btn')?.addEventListener('click', async () => {
      await fetch('/api/auth/logout', { method: 'POST' });
      location.href = '/login';
    });

    document.querySelectorAll('a[href="#asistente"]').forEach((link) => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        document.getElementById('assistant-fab')?.click();
      });
    });
  </script>
</BaseLayout>
