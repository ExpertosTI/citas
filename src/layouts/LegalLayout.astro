---
import BaseLayout from './BaseLayout.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { LEGAL } from '../lib/legal';

interface Props {
  title: string;
  description?: string;
  heading: string;
  intro?: string;
}

const { title, description, heading, intro } = Astro.props;
const pageTitle = `${title} · ${LEGAL.product}`;
const canonical = `${LEGAL.siteUrl}${Astro.url.pathname}`;
---

<BaseLayout title={pageTitle} description={description || title} canonical={canonical}>
  <div class="app-scene min-h-dvh">
    <header class="mx-auto flex max-w-3xl items-center justify-between px-4 py-5">
      <a href="/" class="font-display text-lg font-semibold text-ink">{LEGAL.product}</a>
      <a href="/login" class="btn-ghost !py-2 !px-4 !text-sm">Entrar</a>
    </header>

    <article class="legal-doc mx-auto max-w-3xl px-4 pb-12">
      <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-mustard-deep">Documento legal</p>
      <h1 class="font-display mt-2 text-3xl font-semibold tracking-tight text-ink sm:text-4xl">{heading}</h1>
      {intro && <p class="mt-3 text-sm leading-relaxed text-muted">{intro}</p>}
      <p class="mt-2 text-xs text-muted">Última actualización: {LEGAL.lastUpdated}</p>

      <div class="legal-doc__body card mt-8 p-6 sm:p-8">
        <slot />
      </div>

      <p class="mt-6 text-center text-sm text-muted">
        ¿Preguntas? <a class="font-semibold text-mustard-deep hover:underline" href={`mailto:${LEGAL.contactEmail}`}>{LEGAL.contactEmail}</a>
      </p>
    </article>

    <SiteFooter compact />
  </div>
</BaseLayout>
